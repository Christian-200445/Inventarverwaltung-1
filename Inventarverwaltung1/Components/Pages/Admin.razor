@page "/Admin"

@using System.Text
@using System.Linq
@using Radzen
@using Radzen.Blazor
@using Inventarverwaltung1.Data
@using Microsoft.EntityFrameworkCore
@inject NotificationService NotificationService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IDbContextFactory<AppDbContext> DbFactory

<style>
    :root {
        --bg: #f3f5f9;
        --card: #ffffff;
        --muted: #6b7280;
        --text: #111827;
        --line: rgba(17,24,39,.10);
        --shadow: 0 16px 40px rgba(17,24,39,.10);
        --shadow2: 0 10px 24px rgba(17,24,39,.08);
        --blue1: #122b73;
        --blue2: #2f63e6;
        --blue3: #59a7ff;
        --radius: 20px;
    }

    * { box-sizing: border-box; }

    .page {
        min-height: 100vh;
        background: radial-gradient(1200px 520px at 50% -120px, rgba(89,167,255,.22), transparent 70%), radial-gradient(900px 420px at 85% 0px, rgba(47,99,230,.14), transparent 55%), linear-gradient(#ffffff, var(--bg));
        padding: 22px 18px 60px;
        color: var(--text);
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
    }

    .wrap { max-width: 1320px; margin: 0 auto; }

    .top {
        border-radius: 26px;
        padding: 16px;
        background: linear-gradient(95deg, var(--blue1), var(--blue2) 55%, var(--blue3));
        box-shadow: var(--shadow);
        color: #fff;
        position: relative;
        overflow: hidden;
        min-height: 92px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

    .top:before {
        content: "";
        position: absolute;
        inset: -120px -120px auto auto;
        width: 340px; height: 340px;
        background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.18), transparent 60%);
        transform: rotate(8deg);
        pointer-events: none;
    }

    .brand { display: flex; align-items: center; gap: 14px; z-index: 1; min-width: 0; }

    .title {
        font-size: 22px; font-weight: 900; letter-spacing: .01em;
        line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    .iv-user { position: relative; z-index: 1000; display: flex; align-items: center; }

    .iv-avatar {
        width: 42px; height: 42px; border-radius: 999px;
        border: 1px solid rgba(255,255,255,.25);
        background: rgba(255,255,255,.18);
        color: #fff; font-weight: 900; cursor: pointer;
        box-shadow: 0 10px 18px rgba(0,0,0,.12);
        display: grid; place-items: center; user-select: none;
    }

    .iv-menu {
        position: fixed; top: 110px; right: 38px; width: 180px;
        background: #fff; border: 1px solid rgba(0,0,0,.10);
        border-radius: 14px; box-shadow: 0 14px 36px rgba(0,0,0,.12);
        padding: 10px; z-index: 999999;
    }

    .iv-menu-name { font-weight: 900; color: #111827; }
    .iv-menu-sub { font-size: 12px; color: #6b7280; margin-bottom: 10px; }

    .iv-logout {
        width: 100%; border: none; border-radius: 12px;
        padding: 10px 12px; cursor: pointer; font-weight: 800;
        background: #ef4444; color: white;
    }
    .iv-logout:hover { filter: brightness(1.05); }

    .kpis { margin-top: 16px; display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 14px; }

    .kpi {
        background: var(--card); border: 1px solid var(--line);
        border-radius: var(--radius); box-shadow: var(--shadow2);
        padding: 14px; overflow: hidden;
    }

    .kpiTop { display: flex; align-items: center; justify-content: space-between; gap: 10px; }

    .kpiIcon {
        width: 38px; height: 38px; border-radius: 16px;
        display: grid; place-items: center;
        background: rgba(47,99,230,.10); border: 1px solid rgba(47,99,230,.12); font-size: 18px;
    }

    .kpi .label { font-size: 12px; color: var(--muted); }
    .kpi .value { font-size: 26px; font-weight: 900; margin-top: 6px; letter-spacing: .01em; }
    .kpi .hint { font-size: 12px; color: var(--muted); margin-top: 2px; }

    .grid { margin-top: 14px; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; align-items: start; }

    .card {
        background: var(--card); border: 1px solid var(--line);
        border-radius: var(--radius); box-shadow: var(--shadow2); padding: 14px;
    }

    .sectionHead {
        display: flex; align-items: flex-start; justify-content: space-between;
        gap: 12px; flex-wrap: wrap;
        padding-bottom: 10px; border-bottom: 1px dashed rgba(17,24,39,.10); margin-bottom: 10px;
    }

    .fieldLabel { display: block; font-size: 12px; color: var(--muted); margin: 0 0 4px 2px; }
    .actions { display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end; justify-content: flex-end; }
    .rowActions { display: flex; gap: 8px; flex-wrap: wrap; }

    .rz-button { border-radius: 12px !important; }
    .rz-dropdown { border-radius: 12px !important; }
    .rz-textbox { border-radius: 12px !important; }
    .rz-datatable, .rz-data-grid { border-radius: 14px !important; overflow: hidden; }

    @@media (max-width: 980px) {
        .kpis { grid-template-columns: 1fr 1fr; }
        .grid { grid-template-columns: 1fr; }
        .top { flex-direction: column; align-items: flex-start; }
    }
    @@media (max-width: 520px) {
        .kpis { grid-template-columns: 1fr; }
    }
</style>

<div class="page">
    <div class="wrap">

        <div class="top">
            <div class="brand">
                <div style="min-width:0">
                    <div class="title">Admin-Dashboard</div>
                </div>
            </div>
            <div class="iv-user">
                <div class="iv-avatar" @onclick="ToggleMenu">@GetInitials(CurrentUserName)</div>
                @if (ShowMenu)
                {
                    <div class="iv-menu">
                        <div class="iv-menu-name">@CurrentUserName</div>
                        <div class="iv-menu-sub">Rolle: Administrator</div>
                        <button class="iv-logout" @onclick="Logout">Abmelden</button>
                    </div>
                }
            </div>
        </div>

        <div class="kpis">
            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Nutzer</div>
                        <div class="value">@Users.Count</div>
                        <div class="hint">Konten im System</div>
                    </div>
                    <div class="kpiIcon">👤</div>
                </div>
            </div>
            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Registrierte Nutzer</div>
                        <div class="value">@Users.Count</div>
                        <div class="hint">Gesamt</div>
                    </div>
                    <div class="kpiIcon">✅</div>
                </div>
            </div>
            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Stammdaten-Typ</div>
                        <div class="value">@SelectedMasterType</div>
                        <div class="hint">Aktuell gewählt</div>
                    </div>
                    <div class="kpiIcon">📚</div>
                </div>
            </div>
            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Einträge aktuell</div>
                        <div class="value">@FilteredMasterRows.Count</div>
                        <div class="hint">@SelectedMasterType</div>
                    </div>
                    <div class="kpiIcon">🧾</div>
                </div>
            </div>
        </div>

        <div class="grid">

            <!-- Nutzer verwalten -->
            <div class="card">
                <div class="sectionHead">
                    <div class="actions">
                        <div style="min-width:240px;">
                            <label class="fieldLabel">Suche (Name/E-Mail)</label>
                            <RadzenTextBox Style="width:100%" @bind-Value="@UserSearch"
                                           @oninput="@(e => { UserSearch = e.Value?.ToString() ?? ""; ApplyUserFilter(); })" />
                        </div>
                    </div>
                </div>

                <div class="actions" style="margin-bottom:10px;">
                    <RadzenButton Text="Neuer Benutzer" Icon="person_add" ButtonStyle="ButtonStyle.Success" Click="@AddUserRow" />
                    <RadzenButton Text="→ Clipboard" Icon="content_copy" ButtonStyle="ButtonStyle.Light" Click="@CopyUsersToClipboard" />
                    <RadzenButton Text="→ CSV" Icon="download" ButtonStyle="ButtonStyle.Light" Click="@DownloadUsersCsv" />
                </div>

                <RadzenDataGrid @ref="_usersGrid"
                                TItem="UserRow"
                                Data="@FilteredUsers"
                                AllowPaging="true" PageSize="8"
                                AllowSorting="true"
                                EditMode="DataGridEditMode.Single"
                                RowUpdate="@OnUserUpdate"
                                RowCreate="@OnUserCreate">
                    <Columns>
                        <RadzenDataGridColumn TItem="UserRow" Property="Vorname" Title="Vorname">
                            <EditTemplate Context="u">
                                <RadzenTextBox Style="width:100%" @bind-Value="u.Vorname" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="UserRow" Property="Nachname" Title="Nachname">
                            <EditTemplate Context="u">
                                <RadzenTextBox Style="width:100%" @bind-Value="u.Nachname" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="UserRow" Property="Mail" Title="E-Mail">
                            <EditTemplate Context="u">
                                <RadzenTextBox Style="width:100%" @bind-Value="u.Mail" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="UserRow" Title="Aktionen" Width="220px">
                            <Template Context="u">
                                <div class="rowActions">
                                    <RadzenButton Size="ButtonSize.Small" Text="Bearbeiten" Icon="edit"
                                                  ButtonStyle="ButtonStyle.Light" Click="@(() => BeginEditUser(u))" />
                                    <RadzenButton Size="ButtonSize.Small" Text="Löschen" Icon="delete"
                                                  ButtonStyle="ButtonStyle.Danger" Click="@(() => DeleteUser(u))" />
                                </div>
                            </Template>
                            <EditTemplate Context="u">
                                <div class="rowActions">
                                    <RadzenButton Size="ButtonSize.Small" Text="Speichern" Icon="save"
                                                  ButtonStyle="ButtonStyle.Success" Click="@(() => SaveUser(u))" />
                                    <RadzenButton Size="ButtonSize.Small" Text="Abbrechen" Icon="cancel"
                                                  ButtonStyle="ButtonStyle.Light" Click="@(() => CancelEditUser(u))" />
                                </div>
                            </EditTemplate>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>

            <!-- Stammdaten aus DB -->
            <div class="card">
                <div class="sectionHead">
                    <div class="actions">
                        <div style="min-width:200px;">
                            <label class="fieldLabel">Stammdaten-Typ</label>
                            <RadzenDropDown TValue="string"
                                            Data="@MasterTypeOptions"
                                            @bind-Value="@SelectedMasterType"
                                            Change="@OnMasterTypeChanged"
                                            Style="width:100%" />
                        </div>
                        <div style="min-width:200px;">
                            <label class="fieldLabel">Suche</label>
                            <RadzenTextBox Style="width:100%" @bind-Value="@MasterSearch"
                                           @oninput="@(e => { MasterSearch = e.Value?.ToString() ?? ""; ApplyMasterFilter(); })"
                                           Placeholder="Beschreibung suchen…" />
                        </div>
                    </div>
                </div>

                <div class="actions" style="margin-bottom:10px;">
                    <RadzenButton Text="Neuer Eintrag" Icon="add_circle" ButtonStyle="ButtonStyle.Success" Click="@AddMasterRow" />
                    <RadzenButton Text="→ Clipboard" Icon="content_copy" ButtonStyle="ButtonStyle.Light" Click="@CopyMasterToClipboard" />
                    <RadzenButton Text="→ CSV" Icon="download" ButtonStyle="ButtonStyle.Light" Click="@DownloadMasterCsv" />
                </div>

                <RadzenDataGrid @ref="_masterGrid"
                                TItem="MasterRow"
                                Data="@FilteredMasterRows"
                                AllowPaging="true" PageSize="8"
                                AllowSorting="true"
                                EditMode="DataGridEditMode.Single"
                                RowUpdate="@OnMasterUpdate"
                                RowCreate="@OnMasterCreate">
                    <Columns>
                        <RadzenDataGridColumn TItem="MasterRow" Property="Beschreibung" Title="Beschreibung">
                            <EditTemplate Context="m">
                                <RadzenTextBox Style="width:100%" @bind-Value="m.Beschreibung" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="MasterRow" Title="Aktionen" Width="220px">
                            <Template Context="m">
                                <div class="rowActions">
                                    <RadzenButton Size="ButtonSize.Small" Text="Bearbeiten" Icon="edit"
                                                  ButtonStyle="ButtonStyle.Light" Click="@(() => BeginEditMaster(m))" />
                                    <RadzenButton Size="ButtonSize.Small" Text="Löschen" Icon="delete"
                                                  ButtonStyle="ButtonStyle.Danger" Click="@(() => DeleteMaster(m))" />
                                </div>
                            </Template>
                            <EditTemplate Context="m">
                                <div class="rowActions">
                                    <RadzenButton Size="ButtonSize.Small" Text="Speichern" Icon="save"
                                                  ButtonStyle="ButtonStyle.Success" Click="@(() => SaveMaster(m))" />
                                    <RadzenButton Size="ButtonSize.Small" Text="Abbrechen" Icon="cancel"
                                                  ButtonStyle="ButtonStyle.Light" Click="@(() => CancelEditMaster(m))" />
                                </div>
                            </EditTemplate>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>

        </div>
    </div>
</div>

@code {
    private bool _jsReady;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var js = @"
(function(){
  window.invAdmin = window.invAdmin || {};
  window.invAdmin.copyText = async function(text){
    try{ await navigator.clipboard.writeText(text); }
    catch(e){
      const ta = document.createElement('textarea');
      ta.value = text; document.body.appendChild(ta);
      ta.select(); document.execCommand('copy'); ta.remove();
    }
  };
  window.invAdmin.downloadTextFile = function(fileName, mimeType, text){
    const blob = new Blob([text], { type: mimeType });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = fileName;
    document.body.appendChild(a); a.click(); a.remove();
    URL.revokeObjectURL(url);
  };
})();";
        await JS.InvokeVoidAsync("eval", js);
        _jsReady = true;
    }

    // --- Avatar / Menu ---
    private bool ShowMenu = false;
    private string CurrentUserName = "Administrator";
    private void ToggleMenu() => ShowMenu = !ShowMenu;

    private void Logout()
    {
        ShowMenu = false;
        NotificationService.Notify(NotificationSeverity.Info, "Abmeldung", "Du wurdest abgemeldet.");
        Nav.NavigateTo("/login");
    }

    // =====================================================================
    // BENUTZER
    // =====================================================================
    private RadzenDataGrid<UserRow>? _usersGrid;
    private List<UserRow> Users = new();
    private List<UserRow> FilteredUsers = new();
    private string UserSearch = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersFromDb();
        await LoadMasterFromDb();
    }

    private async Task LoadUsersFromDb()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        Users = (await db.Benutzer.ToListAsync())
            .Select(b => new UserRow { Id = b.Id, Vorname = b.Vorname, Nachname = b.Nachname, Mail = b.Mail })
            .ToList();
        ApplyUserFilter();
    }

    private void ApplyUserFilter()
    {
        var q = UserSearch?.Trim().ToLowerInvariant() ?? "";
        FilteredUsers = Users
            .Where(u => string.IsNullOrEmpty(q) ||
                        u.Vorname.ToLowerInvariant().Contains(q) ||
                        u.Nachname.ToLowerInvariant().Contains(q) ||
                        u.Mail.ToLowerInvariant().Contains(q))
            .ToList();
    }

    private void AddUserRow()
    {
        var row = new UserRow();
        Users.Insert(0, row);
        ApplyUserFilter();
        _usersGrid?.EditRow(row);
    }

    private void BeginEditUser(UserRow u) => _usersGrid?.EditRow(u);

    private async Task SaveUser(UserRow u)
    {
        if (string.IsNullOrWhiteSpace(u.Vorname) || string.IsNullOrWhiteSpace(u.Nachname))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Validierung", "Vor- und Nachname dürfen nicht leer sein.");
            return;
        }
        await _usersGrid!.UpdateRow(u);
    }

    private void CancelEditUser(UserRow u)
    {
        _usersGrid?.CancelEditRow(u);
        if (u.Id == Guid.Empty) { Users.Remove(u); ApplyUserFilter(); }
    }

    private async Task DeleteUser(UserRow u)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var b = await db.Benutzer.FindAsync(u.Id);
        if (b != null) { db.Benutzer.Remove(b); await db.SaveChangesAsync(); }
        Users.Remove(u);
        ApplyUserFilter();
        NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Gelöscht.");
    }

    private async void OnUserUpdate(UserRow u)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var b = await db.Benutzer.FindAsync(u.Id);
        if (b != null) { b.Vorname = u.Vorname; b.Nachname = u.Nachname; b.Mail = u.Mail; await db.SaveChangesAsync(); }
        // Grid neu laden → sofortige Aktualisierung
        await LoadUsersFromDb();
        StateHasChanged();
        NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Gespeichert.");
    }

    private async void OnUserCreate(UserRow u)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var b = new Benutzer { Id = Guid.NewGuid(), Vorname = u.Vorname, Nachname = u.Nachname, Mail = u.Mail };
        db.Benutzer.Add(b);
        await db.SaveChangesAsync();
        // Grid neu laden → neuer Eintrag erscheint sofort
        await LoadUsersFromDb();
        StateHasChanged();
        NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Erstellt.");
    }

    // =====================================================================
    // STAMMDATEN – echte DB
    // =====================================================================
    private RadzenDataGrid<MasterRow>? _masterGrid;
    private readonly List<string> MasterTypeOptions = new() { "Fach", "Abteilung", "Gruppe", "Ort" };
    private string SelectedMasterType = "Fach";

    // Alle Daten aus DB + gefilterter View
    private List<MasterRow> MasterRows = new();
    private List<MasterRow> FilteredMasterRows = new();
    private string MasterSearch = "";

    private async Task LoadMasterFromDb()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        MasterRows = SelectedMasterType switch
        {
            "Fach" => (await db.Fach.ToListAsync())
                        .Select(x => new MasterRow { Id = x.Id, Beschreibung = x.Beschreibung ?? "" })
                        .ToList(),
            // Weitere Typen hier ergänzen sobald Modelle vorhanden
            _ => new()
        };
        ApplyMasterFilter();
    }

    private void ApplyMasterFilter()
    {
        var q = MasterSearch?.Trim().ToLowerInvariant() ?? "";
        FilteredMasterRows = MasterRows
            .Where(m => string.IsNullOrEmpty(q) ||
                        m.Beschreibung.ToLowerInvariant().Contains(q))
            .ToList();
    }

    private async void OnMasterTypeChanged(object? _)
    {
        MasterSearch = ""; // Suchfeld zurücksetzen beim Typ-Wechsel
        await LoadMasterFromDb();
        StateHasChanged();
    }

    private void AddMasterRow()
    {
        // Neue Zeile direkt in FilteredMasterRows UND MasterRows einfügen
        var row = new MasterRow();
        MasterRows.Insert(0, row);
        FilteredMasterRows.Insert(0, row);
        _masterGrid?.EditRow(row);
        StateHasChanged();
    }

    private void BeginEditMaster(MasterRow m) => _masterGrid?.EditRow(m);

    private async Task SaveMaster(MasterRow m)
    {
        if (string.IsNullOrWhiteSpace(m.Beschreibung))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Validierung", "Beschreibung darf nicht leer sein.");
            return;
        }
        await _masterGrid!.UpdateRow(m);
    }

    private void CancelEditMaster(MasterRow m)
    {
        _masterGrid?.CancelEditRow(m);
        if (m.Id == Guid.Empty)
        {
            MasterRows.Remove(m);
            FilteredMasterRows.Remove(m);
        }
        StateHasChanged();
    }

    private async Task DeleteMaster(MasterRow m)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        switch (SelectedMasterType)
        {
            case "Fach":
                var f = await db.Fach.FindAsync(m.Id);
                if (f != null) { db.Fach.Remove(f); await db.SaveChangesAsync(); }
                break;
        }
        // Aus beiden Listen entfernen
        MasterRows.Remove(m);
        FilteredMasterRows.Remove(m);
        StateHasChanged();
        NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Gelöscht.");
    }

    private async void OnMasterUpdate(MasterRow m)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        switch (SelectedMasterType)
        {
            case "Fach":
                var f = await db.Fach.FindAsync(m.Id);
                if (f != null) { f.Beschreibung = m.Beschreibung; await db.SaveChangesAsync(); }
                break;
        }
        // Grid neu laden → zeigt aktualisierten Wert
        await LoadMasterFromDb();
        StateHasChanged();
        NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Gespeichert.");
    }

    private async void OnMasterCreate(MasterRow m)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        switch (SelectedMasterType)
        {
            case "Fach":
                var f = new Fach { Id = Guid.NewGuid(), Beschreibung = m.Beschreibung };
                db.Fach.Add(f);
                await db.SaveChangesAsync();
                m.Id = f.Id; // ID zurückschreiben damit spätere Änderungen funktionieren
                break;
        }
        // Grid neu laden → neuer Eintrag erscheint korrekt
        await LoadMasterFromDb();
        StateHasChanged();
        NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Erstellt.");
    }

    // =====================================================================
    // EXPORT
    // =====================================================================
    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "??";
        if (parts.Length == 1) return new string(parts[0].Take(2).ToArray()).ToUpperInvariant();
        return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}";
    }

    private string UsersToCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Vorname;Nachname;Mail");
        foreach (var u in FilteredUsers)
            sb.AppendLine($"{Clean(u.Vorname)};{Clean(u.Nachname)};{Clean(u.Mail)}");
        return sb.ToString();
    }

    private string MasterToCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Typ;Beschreibung");
        foreach (var m in FilteredMasterRows)
            sb.AppendLine($"{Clean(SelectedMasterType)};{Clean(m.Beschreibung)}");
        return sb.ToString();
    }

    private static string Clean(string s)
        => (s ?? "").Replace(";", ",").Replace("\n", " ").Replace("\r", " ").Trim();

    private async Task CopyUsersToClipboard()
    {
        if (!_jsReady) { NotificationService.Notify(NotificationSeverity.Warning, "Export", "JS nicht bereit."); return; }
        await JS.InvokeVoidAsync("invAdmin.copyText", UsersToCsv());
        NotificationService.Notify(NotificationSeverity.Success, "Export", "Benutzer in Zwischenablage kopiert.");
    }

    private async Task DownloadUsersCsv()
    {
        if (!_jsReady) { NotificationService.Notify(NotificationSeverity.Warning, "Export", "JS nicht bereit."); return; }
        await JS.InvokeVoidAsync("invAdmin.downloadTextFile", "benutzer.csv", "text/csv;charset=utf-8", UsersToCsv());
        NotificationService.Notify(NotificationSeverity.Info, "Export", "CSV Download gestartet.");
    }

    private async Task CopyMasterToClipboard()
    {
        if (!_jsReady) { NotificationService.Notify(NotificationSeverity.Warning, "Export", "JS nicht bereit."); return; }
        await JS.InvokeVoidAsync("invAdmin.copyText", MasterToCsv());
        NotificationService.Notify(NotificationSeverity.Success, "Export", "Stammdaten in Zwischenablage kopiert.");
    }

    private async Task DownloadMasterCsv()
    {
        if (!_jsReady) { NotificationService.Notify(NotificationSeverity.Warning, "Export", "JS nicht bereit."); return; }
        await JS.InvokeVoidAsync("invAdmin.downloadTextFile", $"stammdaten_{SelectedMasterType}.csv", "text/csv;charset=utf-8", MasterToCsv());
        NotificationService.Notify(NotificationSeverity.Info, "Export", "CSV Download gestartet.");
    }

    // =====================================================================
    // DTOs
    // =====================================================================
    public sealed class MasterRow
    {
        public Guid Id { get; set; }
        public string Beschreibung { get; set; } = "";
    }

    public sealed class UserRow
    {
        public Guid Id { get; set; }
        public string Vorname { get; set; } = "";
        public string Nachname { get; set; } = "";
        public string Mail { get; set; } = "";
    }
}
