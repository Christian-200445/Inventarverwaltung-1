@page "/admin"

@using System.Text
@using System.Linq
@using System.Collections.Generic
@using System.Threading.Tasks
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@using Radzen
@using Radzen.Blazor

@inject NotificationService NotificationService
@inject IJSRuntime JS

<style>
    :root {
        --bg: #f3f5f9;
        --card: #ffffff;
        --muted: #6b7280;
        --text: #111827;
        --line: rgba(17,24,39,.08);
        --shadow: 0 16px 40px rgba(17,24,39,.10);
        --shadow2: 0 10px 24px rgba(17,24,39,.08);
        --blue1: #122b73;
        --blue2: #2f63e6;
        --blue3: #59a7ff;
        --radius: 20px;
    }

    * {
        box-sizing: border-box;
    }

    .page {
        min-height: 100vh;
        background: radial-gradient(1200px 520px at 50% -120px, rgba(89,167,255,.22), transparent 70%), radial-gradient(900px 420px at 85% 0px, rgba(47,99,230,.14), transparent 55%), linear-gradient(#ffffff, var(--bg));
        padding: 22px 18px 60px;
        color: var(--text);
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
    }

    .wrap {
        max-width: 1320px;
        margin: 0 auto;
    }
    .top {
        border-radius: calc(var(--radius) + 6px);
        padding: 16px;
        background: linear-gradient(95deg, var(--blue1), var(--blue2) 55%, var(--blue3));
        box-shadow: var(--shadow);
        color: #fff;
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: 14px;
        position: relative;
        overflow: hidden;
    }

        .top:before {
            content: "";
            position: absolute;
            inset: -120px -120px auto auto;
            width: 320px;
            height: 320px;
            background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.18), transparent 60%);
            transform: rotate(8deg);
            pointer-events: none;
        }

    .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        z-index: 1;
        min-width: 0;
    }

    .logo {
        width: 46px;
        height: 46px;
        border-radius: 16px;
        background: rgba(255,255,255,.16);
        display: grid;
        place-items: center;
        border: 1px solid rgba(255,255,255,.22);
        box-shadow: 0 10px 22px rgba(0,0,0,.10);
        flex: 0 0 auto;
    }

    .title {
        font-size: 22px;
        font-weight: 900;
        letter-spacing: .01em;
        line-height: 1.05;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sub {
        opacity: .92;
        font-size: 12px;
        margin-top: 6px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
    }

    .chip {
        display: inline-flex;
        gap: 8px;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.20);
        backdrop-filter: blur(6px);
        font-size: 12px;
        white-space: nowrap;
    }

    .pill {
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.20);
        backdrop-filter: blur(8px);
        box-shadow: 0 10px 22px rgba(0,0,0,.12);
        min-width: 340px;
        justify-content: flex-end;
    }

    .avatar {
        width: 36px;
        height: 36px;
        border-radius: 999px;
        background: rgba(255,255,255,.22);
        display: grid;
        place-items: center;
        border: 1px solid rgba(255,255,255,.25);
        font-weight: 900;
        box-shadow: 0 10px 18px rgba(0,0,0,.12);
        flex: 0 0 auto;
    }

    .roleLine {
        font-size: 12px;
        opacity: .95;
        display: flex;
        gap: 8px;
        align-items: center;
        justify-content: flex-end;
        margin-top: 2px;
    }
    .kpis {
        margin-top: 14px;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
    }

    .kpi {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow2);
        padding: 14px;
        transition: transform .15s ease, box-shadow .15s ease;
        overflow: hidden;
    }

        .kpi:hover {
            transform: translateY(-2px);
            box-shadow: 0 18px 40px rgba(17,24,39,.12);
        }

    .kpiTop {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .kpiIcon {
        width: 34px;
        height: 34px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: rgba(47,99,230,.10);
        border: 1px solid rgba(47,99,230,.12);
        font-size: 16px;
    }

    .kpi .label {
        font-size: 12px;
        color: var(--muted);
    }

    .kpi .value {
        font-size: 26px;
        font-weight: 900;
        margin-top: 6px;
        letter-spacing: .01em;
    }

    .kpi .hint {
        font-size: 12px;
        color: var(--muted);
        margin-top: 2px;
    }

    .kpiBar {
        margin-top: 10px;
        height: 6px;
        border-radius: 999px;
        background: rgba(17,24,39,.06);
        overflow: hidden;
    }

        .kpiBar > span {
            display: block;
            height: 100%;
            width: 62%;
            background: linear-gradient(90deg, rgba(47,99,230,.35), rgba(89,167,255,.70));
            border-radius: 999px;
        }
    .grid {
        margin-top: 14px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
    }

    .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow2);
        padding: 14px;
    }

    .row2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        align-items: start;
    }

    .sectionHead {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        padding-bottom: 10px;
        border-bottom: 1px dashed rgba(17,24,39,.10);
        margin-bottom: 10px;
    }

    .h3 {
        margin: 0;
        font-size: 15px;
        font-weight: 900;
        letter-spacing: .01em;
    }

    .hint {
        color: var(--muted);
        font-size: 12px;
        margin-top: 4px;
    }

    .fieldLabel {
        display: block;
        font-size: 12px;
        color: var(--muted);
        margin: 0 0 4px 2px;
    }

    .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-end;
    }

    .rowActions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .rz-button {
        border-radius: 12px !important;
    }

    .rz-dropdown {
        border-radius: 12px !important;
    }

    .rz-datatable, .rz-data-grid {
        border-radius: 14px !important;
        overflow: hidden;
    }
    media (max-width: 980px) {
        .kpis {
            grid-template-columns: 1fr 1fr;
        }

        .row2 {
            grid-template-columns: 1fr;
        }

        .pill {
            min-width: auto;
        }

        .top {
            grid-template-columns: 1fr;
        }
    }

    media (max-width: 520px) {
        .kpis {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page">
    <div class="wrap">

        <div class="top">
            <div class="brand">
                <div class="logo" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M4 7h16M7 7V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2M6 7v14h12V7"
                              stroke="white" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </div>
                <div style="min-width:0">
                    <div class="title">Admin · Inventarverwaltung</div>
                    <div class="sub">
                        <span class="chip">🛡️ Admin-Funktionen</span>
                        <span class="chip">⚡ Inline bearbeiten</span>
                        <span class="chip">⬇️ Export CSV / Clipboard</span>
                    </div>
                </div>
            </div>

            <div class="pill">
                <div class="avatar">@GetInitials(CurrentUserName)</div>
                <div style="text-align:right">
                    <div style="font-weight:900;line-height:1">@CurrentUserName</div>
                    <div class="roleLine">
                        Rolle:
                        <RadzenDropDown TValue="string"
                                        Data="@Roles"
                                        @bind-Value="@SelectedRole"
                                        Change="@OnRoleChanged"
                                        Style="width:170px;background:transparent;color:white;border:0;font-weight:900" />
                    </div>
                </div>
            </div>
        </div>

        <div class="kpis">
            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Nutzer</div>
                        <div class="value">@Users.Count</div>
                        <div class="hint">Konten im System</div>
                    </div>
                    <div class="kpiIcon" aria-hidden="true">👤</div>
                </div>
                <div class="kpiBar"><span style="width:72%"></span></div>
            </div>

            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Admins</div>
                        <div class="value">@Users.Count(u => u.Role == "Administrator")</div>
                        <div class="hint">Vollzugriff</div>
                    </div>
                    <div class="kpiIcon" aria-hidden="true">🛡️</div>
                </div>
                <div class="kpiBar"><span style="width:55%"></span></div>
            </div>

            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Stammdaten-Typen</div>
                        <div class="value">@MasterTypes.Count</div>
                        <div class="hint">Abteilungen, Fächer, …</div>
                    </div>
                    <div class="kpiIcon" aria-hidden="true">📚</div>
                </div>
                <div class="kpiBar"><span style="width:64%"></span></div>
            </div>

            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Einträge aktuell</div>
                        <div class="value">@MasterRows.Count</div>
                        <div class="hint">@SelectedMasterType</div>
                    </div>
                    <div class="kpiIcon" aria-hidden="true">🧾</div>
                </div>
                <div class="kpiBar"><span style="width:78%"></span></div>
            </div>
        </div>

        <div class="grid">
            <div class="row2">

                <div class="card">
                    <div class="sectionHead">
                        <div>
                            <div class="h3">Nutzerverwaltung</div>
                            <div class="hint">Inline bearbeiten (kein Dialog). Nur Admin darf speichern.</div>
                        </div>

                        <div class="actions">
                            <RadzenButton Text="Neuer Nutzer" Icon="person_add" ButtonStyle="ButtonStyle.Success"
                                          Disabled="@(!IsAdmin)" Click="@AddUserRow" />
                            <RadzenButton Text="Änderungen speichern" Icon="save" ButtonStyle="ButtonStyle.Primary"
                                          Disabled="@(!IsAdmin)" Click="@SaveUsers" />
                        </div>
                    </div>

                    <RadzenDataGrid @ref="_usersGrid"
                                    TItem="UserRow"
                                    Data="@Users"
                                    AllowPaging="true" PageSize="8"
                                    AllowSorting="true"
                                    EditMode="DataGridEditMode.Single"
                                    RowUpdate="@OnUserUpdate"
                                    RowCreate="@OnUserCreate">

                        <Columns>
                            <RadzenDataGridColumn TItem="UserRow" Property="Name" Title="Name">
                                <EditTemplate Context="u">
                                    <RadzenTextBox Style="width:100%" @bind-Value="u.Name" />
                                </EditTemplate>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="UserRow" Property="Email" Title="E-Mail">
                                <EditTemplate Context="u">
                                    <RadzenTextBox Style="width:100%" @bind-Value="u.Email" />
                                </EditTemplate>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="UserRow" Property="Role" Title="Rolle" Width="170px">
                                <Template Context="u">
                                    <RadzenBadge Text="@u.Role"
                                                 Style="background: rgba(37,99,235,.10); color:#1e3a8a; border:1px solid rgba(17,24,39,.08);" />
                                </Template>
                                <EditTemplate Context="u">
                                    <RadzenDropDown TValue="string" Data="@Roles" Style="width:100%" @bind-Value="u.Role" />
                                </EditTemplate>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="UserRow" Title="Aktionen" Width="220px">
                                <Template Context="u">
                                    <div class="rowActions">
                                        <RadzenButton Size="ButtonSize.Small" Text="Bearbeiten" ButtonStyle="ButtonStyle.Light"
                                                      Disabled="@(!IsAdmin)" Click="@(() => BeginEditUser(u))" />
                                        <RadzenButton Size="ButtonSize.Small" Text="Löschen" ButtonStyle="ButtonStyle.Danger"
                                                      Disabled="@(!IsAdmin)" Click="@(() => DeleteUser(u))" />
                                    </div>
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </div>

                <div class="card">
                    <div class="sectionHead">
                        <div>
                            <div class="h3">Stammdaten</div>
                            <div class="hint">Typ wählen · Inline editieren · Export CSV/Clipboard</div>
                        </div>

                        <div class="actions" style="align-items:end;">
                            <div style="min-width:240px;">
                                <label class="fieldLabel">Stammdaten-Typ</label>
                                <RadzenDropDown TValue="string"
                                                Data="@MasterTypes"
                                                @bind-Value="@SelectedMasterType"
                                                Change="@OnMasterTypeChanged"
                                                Style="width:100%" />
                            </div>

                            <RadzenButton Text="Neuer Eintrag" Icon="add_circle" ButtonStyle="ButtonStyle.Success"
                                          Disabled="@(!IsAdmin)" Click="@AddMasterRow" />
                        </div>
                    </div>

                    <div class="actions" style="margin:10px 0;">
                        <RadzenButton Text="Stammdaten → Clipboard" Icon="content_copy" ButtonStyle="ButtonStyle.Light"
                                      Disabled="@(!IsAdmin)" Click="@CopyMasterToClipboard" />
                        <RadzenButton Text="Stammdaten → CSV" Icon="download" ButtonStyle="ButtonStyle.Light"
                                      Disabled="@(!IsAdmin)" Click="@DownloadMasterCsv" />
                    </div>

                    <RadzenDataGrid @ref="_masterGrid"
                                    TItem="MasterRow"
                                    Data="@MasterRows"
                                    AllowPaging="true" PageSize="8"
                                    AllowSorting="true"
                                    EditMode="DataGridEditMode.Single"
                                    RowUpdate="@OnMasterUpdate"
                                    RowCreate="@OnMasterCreate">

                        <Columns>
                            <RadzenDataGridColumn TItem="MasterRow" Property="Value" Title="Wert">
                                <EditTemplate Context="m">
                                    <RadzenTextBox Style="width:100%" @bind-Value="m.Value" />
                                </EditTemplate>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="MasterRow" Title="Aktionen" Width="220px">
                                <Template Context="m">
                                    <div class="rowActions">
                                        <RadzenButton Size="ButtonSize.Small" Text="Bearbeiten" ButtonStyle="ButtonStyle.Light"
                                                      Disabled="@(!IsAdmin)" Click="@(() => BeginEditMaster(m))" />
                                        <RadzenButton Size="ButtonSize.Small" Text="Löschen" ButtonStyle="ButtonStyle.Danger"
                                                      Disabled="@(!IsAdmin)" Click="@(() => DeleteMaster(m))" />
                                    </div>
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </div>

            </div>
        </div>

    </div>
</div>

@code {
    private bool _jsReady;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var js = @"
      (function(){
        window.invAdmin = window.invAdmin || {};
        window.invAdmin.copyText = async function(text){
          try{ await navigator.clipboard.writeText(text); }
          catch(e){
            const ta = document.createElement('textarea');
            ta.value = text; document.body.appendChild(ta);
            ta.select(); document.execCommand('copy'); ta.remove();
          }
        };
        window.invAdmin.downloadTextFile = function(fileName, mimeType, text){
          const blob = new Blob([text], { type: mimeType });
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url; a.download = fileName;
          document.body.appendChild(a); a.click(); a.remove();
          URL.revokeObjectURL(url);
        };
      })();
    ";

        await JS.InvokeVoidAsync("eval", js);
        _jsReady = true;
    }

    private string CurrentUserName = "Herr Müller";
    private readonly List<string> Roles = new() { "Lehrer", "Verantwortlicher", "Administrator" };
    private string SelectedRole = "Administrator";
    private bool IsAdmin => SelectedRole == "Administrator";

    private void OnRoleChanged(object? _)
    {
        NotificationService.Notify(NotificationSeverity.Info, "Rolle geändert", $"Aktuelle Rolle: {SelectedRole}");
    }

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "??";
        if (parts.Length == 1) return new string(parts[0].Take(2).ToArray()).ToUpperInvariant();
        return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[parts.Length - 1][0])}";
    }

    private List<UserRow> Users = new()
    {
        new UserRow("Herr Müller", "mueller@schule.de", "Administrator"),
        new UserRow("Frau Schmidt", "schmidt@schule.de", "Verantwortlicher"),
        new UserRow("Herr Becker", "becker@schule.de", "Lehrer")
    };

    private RadzenDataGrid<UserRow>? _usersGrid;
    private RadzenDataGrid<MasterRow>? _masterGrid;

    private void AddUserRow()
    {
        if (!IsAdmin) return;
        var row = new UserRow("", "", "Lehrer");
        Users.Insert(0, row);
        _usersGrid?.EditRow(row);
    }

    private void BeginEditUser(UserRow u)
    {
        if (!IsAdmin) return;
        _usersGrid?.EditRow(u);
    }

    private void DeleteUser(UserRow u)
    {
        if (!IsAdmin) return;
        Users.Remove(u);
        NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Gelöscht (Demo).");
    }

    private void SaveUsers()
    {
        if (!IsAdmin) return;
        NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Änderungen gespeichert (Demo).");
    }

    private void OnUserUpdate(UserRow u)
    {
        if (!IsAdmin) return;

        if (string.IsNullOrWhiteSpace(u.Name) || string.IsNullOrWhiteSpace(u.Email))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Validierung", "Name und E-Mail dürfen nicht leer sein.");
            return;
        }

        NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Aktualisiert (Demo).");
    }

    private void OnUserCreate(UserRow u)
    {
        if (!IsAdmin) return;
        NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Erstellt (Demo).");
    }
    private readonly List<string> MasterTypes = new() { "Abteilungen", "Gruppen", "Fächer", "Orte", "Lehrer" };
    private string SelectedMasterType = "Abteilungen";

    private readonly Dictionary<string, List<string>> MasterStore = new()
    {
        ["Abteilungen"] = new() { "IT", "AV", "Metall", "Elektro" },
        ["Gruppen"] = new() { "EDV", "Lehr-Lernmittel" },
        ["Fächer"] = new() { "Mathe", "Physik", "Deutsch", "Informatik" },
        ["Orte"] = new() { "Raum 204", "Raum 110", "Lager" },
        ["Lehrer"] = new() { "Herr Müller", "Frau Schmidt", "Herr Becker" }
    };

    private List<MasterRow> MasterRows = new();

    protected override void OnInitialized()
    {
        LoadMasterSet();
    }

    private void OnMasterTypeChanged(object? _)
    {
        LoadMasterSet();
    }

    private void LoadMasterSet()
    {
        MasterRows = MasterStore[SelectedMasterType]
            .Select(v => new MasterRow { Value = v })
            .ToList();
    }

    private void PersistMasterSet()
    {
        MasterStore[SelectedMasterType] = MasterRows
            .Where(x => !string.IsNullOrWhiteSpace(x.Value))
            .Select(x => x.Value.Trim())
            .Distinct()
            .ToList();
    }

    private void AddMasterRow()
    {
        if (!IsAdmin) return;
        var row = new MasterRow { Value = "" };
        MasterRows.Insert(0, row);
        _masterGrid?.EditRow(row);
    }

    private void BeginEditMaster(MasterRow m)
    {
        if (!IsAdmin) return;
        _masterGrid?.EditRow(m);
    }

    private void DeleteMaster(MasterRow m)
    {
        if (!IsAdmin) return;
        MasterRows.Remove(m);
        PersistMasterSet();
        NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Gelöscht (Demo).");
    }

    private void OnMasterUpdate(MasterRow m)
    {
        if (!IsAdmin) return;
        PersistMasterSet();
        NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Gespeichert (Demo).");
    }

    private void OnMasterCreate(MasterRow m)
    {
        if (!IsAdmin) return;
        PersistMasterSet();
        NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Erstellt (Demo).");
    }

    private string MasterToCsv(string type)
    {
        var sb = new StringBuilder();
        sb.AppendLine("Typ;Wert");

        foreach (var v in MasterStore[type])
        {
            var clean = v.Replace(";", ",").Replace("\n", " ").Replace("\r", " ").Trim();
            sb.AppendLine($"{type};{clean}");
        }

        return sb.ToString();
    }

    private async Task CopyMasterToClipboard()
    {
        if (!IsAdmin) return;
        if (!_jsReady)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Export", "JS nicht bereit.");
            return;
        }

        var csv = MasterToCsv(SelectedMasterType);
        await JS.InvokeVoidAsync("invAdmin.copyText", csv);
        NotificationService.Notify(NotificationSeverity.Success, "Export", "Stammdaten in Zwischenablage kopiert.");
    }

    private async Task DownloadMasterCsv()
    {
        if (!IsAdmin) return;
        if (!_jsReady)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Export", "JS nicht bereit.");
            return;
        }

        var csv = MasterToCsv(SelectedMasterType);
        await JS.InvokeVoidAsync(
            "invAdmin.downloadTextFile",
            $"stammdaten_{SelectedMasterType}.csv",
            "text/csv;charset=utf-8",
            csv
        );

        NotificationService.Notify(NotificationSeverity.Info, "Export", "CSV Download gestartet.");
    }
    public sealed class MasterRow
    {
        public string Value { get; set; } = "";
    }

    public sealed class UserRow
    {
        public UserRow() { }
        public UserRow(string name, string email, string role)
        {
            Name = name;
            Email = email;
            Role = role;
        }

        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "Lehrer";
    }
}
