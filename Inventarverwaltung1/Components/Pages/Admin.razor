@page "/admin"

@using System.Text
@using System.Linq
@using Radzen
@using Radzen.Blazor
@inject NotificationService NotificationService
@inject IJSRuntime JS
@inject NavigationManager Nav

<style>
    :root {
        --bg: #f3f5f9;
        --card: #ffffff;
        --muted: #6b7280;
        --text: #111827;
        --line: rgba(17,24,39,.10);
        --shadow: 0 16px 40px rgba(17,24,39,.10);
        --shadow2: 0 10px 24px rgba(17,24,39,.08);
        --blue1: #122b73;
        --blue2: #2f63e6;
        --blue3: #59a7ff;
        --radius: 20px;
    }

    * {
        box-sizing: border-box;
    }

    .page {
        min-height: 100vh;
        background: radial-gradient(1200px 520px at 50% -120px, rgba(89,167,255,.22), transparent 70%), radial-gradient(900px 420px at 85% 0px, rgba(47,99,230,.14), transparent 55%), linear-gradient(#ffffff, var(--bg));
        padding: 22px 18px 60px;
        color: var(--text);
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
    }

    .wrap {
        max-width: 1320px;
        margin: 0 auto;
    }

    /*Topbar*/
    .top {
        border-radius: 26px;
        padding: 16px;
        background: linear-gradient(95deg, var(--blue1), var(--blue2) 55%, var(--blue3));
        box-shadow: var(--shadow);
        color: #fff;
        position: relative;
        overflow: hidden;
        min-height: 92px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

        .top:before {
            content: "";
            position: absolute;
            inset: -120px -120px auto auto;
            width: 340px;
            height: 340px;
            background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.18), transparent 60%);
            transform: rotate(8deg);
            pointer-events: none;
        }

    .brand {
        display: flex;
        align-items: center;
        gap: 14px;
        z-index: 1;
        min-width: 0;
    }

    .logoBox {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        background: rgba(255,255,255,.16);
        border: 1px solid rgba(255,255,255,.22);
        box-shadow: 0 10px 22px rgba(0,0,0,.10);
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        overflow: hidden;
    }

    .title {
        font-size: 22px;
        font-weight: 900;
        letter-spacing: .01em;
        line-height: 1.1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sub {
        opacity: .92;
        font-size: 12px;
        margin-top: 6px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
    }

    .chip {
        display: inline-flex;
        gap: 8px;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.20);
        backdrop-filter: blur(6px);
        font-size: 12px;
        white-space: nowrap;
    }

    /*Avatar und Menu*/
    .iv-user {
        position: relative;
        z-index: 1000;
        display: flex;
        align-items: center;
    }

    .iv-avatar {
        width: 42px;
        height: 42px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.25);
        background: rgba(255,255,255,.18);
        color: #fff;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 10px 18px rgba(0,0,0,.12);
        display: grid;
        place-items: center;
        user-select: none;
    }

    .iv-menu {
        position: fixed;
        top: 110px;
        right: 38px;
        width: 180px;
        background: #fff;
        border: 1px solid rgba(0,0,0,.10);
        border-radius: 14px;
        box-shadow: 0 14px 36px rgba(0,0,0,.12);
        padding: 10px;
        z-index: 999999;
    }

    .iv-menu-name {
        font-weight: 900;
        color: #111827;
    }

    .iv-menu-sub {
        font-size: 12px;
        color: #6b7280;
        margin-bottom: 10px;
    }

    .iv-logout {
        width: 100%;
        border: none;
        border-radius: 12px;
        padding: 10px 12px;
        cursor: pointer;
        font-weight: 800;
        background: #ef4444;
        color: white;
    }

        .iv-logout:hover {
            filter: brightness(1.05);
        }

    /*KPI Cards*/
    .kpis {
        margin-top: 16px;
        display: grid;
        grid-template-columns: repeat(4, minmax(0,1fr));
        gap: 14px;
    }

    .kpi {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow2);
        padding: 14px;
        overflow: hidden;
    }

    .kpiTop {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .kpiIcon {
        width: 38px;
        height: 38px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        background: rgba(47,99,230,.10);
        border: 1px solid rgba(47,99,230,.12);
        font-size: 18px;
    }

    .kpi .label {
        font-size: 12px;
        color: var(--muted);
    }

    .kpi .value {
        font-size: 26px;
        font-weight: 900;
        margin-top: 6px;
        letter-spacing: .01em;
    }

    .kpi .hint {
        font-size: 12px;
        color: var(--muted);
        margin-top: 2px;
    }

    /*Layout Cards*/
    .grid {
        margin-top: 14px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        align-items: start;
    }

    .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow2);
        padding: 14px;
    }

    .sectionHead {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        padding-bottom: 10px;
        border-bottom: 1px dashed rgba(17,24,39,.10);
        margin-bottom: 10px;
    }

    .h3 {
        margin: 0;
        font-size: 15px;
        font-weight: 900;
        letter-spacing: .01em;
    }

    .hint {
        color: var(--muted);
        font-size: 12px;
        margin-top: 4px;
    }

    .fieldLabel {
        display: block;
        font-size: 12px;
        color: var(--muted);
        margin: 0 0 4px 2px;
    }

    .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: flex-end;
        justify-content: flex-end;
    }

    .rowActions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .rz-button {
        border-radius: 12px !important;
    }

    .rz-dropdown {
        border-radius: 12px !important;
    }

    .rz-textbox {
        border-radius: 12px !important;
    }

    .rz-datatable, .rz-data-grid {
        border-radius: 14px !important;
        overflow: hidden;
    }

    media (max-width: 980px) {
        .kpis {
            grid-template-columns: 1fr 1fr;
        }

        .grid {
            grid-template-columns: 1fr;
        }

        .top {
            flex-direction: column;
            align-items: flex-start;
        }
    }
    media (max-width: 520px) {
        .kpis {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page">
    <div class="wrap">

        <div class="top">
            <div class="brand">

                <div style="min-width:0">
                    <div class="title">Admin-Dashboard</div>
                </div>
            </div>

            <div class="iv-user">
                <div class="iv-avatar" @onclick="ToggleMenu">@GetInitials(CurrentUserName)</div>

                @if (ShowMenu)
                {
                    <div class="iv-menu">
                        <div class="iv-menu-name">@CurrentUserName</div>
                        <div class="iv-menu-sub">Rolle: Administrator</div>
                        <button class="iv-logout" @onclick="Logout">Abmelden</button>
                    </div>
                }
            </div>
        </div>

        <div class="kpis">
            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Nutzer</div>
                        <div class="value">@Users.Count</div>
                        <div class="hint">Konten im System</div>
                    </div>
                    <div class="kpiIcon">👤</div>
                </div>
            </div>

            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Admins</div>
                        <div class="value">@Users.Count(u => u.Role == "Administrator")</div>
                        <div class="hint">Vollzugriff</div>
                    </div>
                    <div class="kpiIcon"></div>
                </div>
            </div>

            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Stammdaten-Typen</div>
                        <div class="value">@MasterTypes.Count</div>
                        <div class="hint">Abteilungen, Fächer, …</div>
                    </div>
                    <div class="kpiIcon">📚</div>
                </div>
            </div>

            <div class="kpi">
                <div class="kpiTop">
                    <div>
                        <div class="label">Einträge aktuell</div>
                        <div class="value">@MasterRows.Count</div>
                        <div class="hint">@SelectedMasterType</div>
                    </div>
                    <div class="kpiIcon">🧾</div>
                </div>
            </div>
        </div>

        <div class="grid">

            <!-- Nutzer verwalten -->
            <div class="card">
                <div class="sectionHead">

                    <div class="actions">
                        <div style="min-width:240px;">
                            <label class="fieldLabel">Suche (Name/E-Mail)</label>
                            <RadzenTextBox Style="width:100%" @bind-Value="@UserSearch" />
                        </div>

                        <div style="min-width:200px;">
                            <label class="fieldLabel">Rolle</label>
                            <RadzenDropDown TValue="string"
                                            Data="@Roles"
                                            @bind-Value="@UserRoleFilter"
                                            Style="width:100%" />
                        </div>

                        <RadzenButton Text="Suchen" Icon="search" ButtonStyle="ButtonStyle.Primary" Click="@ApplyUserFilter" />
                    </div>
                </div>

                <div class="actions" style="margin-bottom:10px;">
                    <RadzenButton Text="Neuer Admin" Icon="person_add" ButtonStyle="ButtonStyle.Success" Click="@AddUserRow" />
                    <RadzenButton Text="Admins → Clipboard" Icon="content_copy" ButtonStyle="ButtonStyle.Light" Click="@CopyUsersToClipboard" />
                    <RadzenButton Text="Admins → CSV" Icon="download" ButtonStyle="ButtonStyle.Light" Click="@DownloadUsersCsv" />
                </div>

                <RadzenDataGrid @ref="_usersGrid"
                                TItem="UserRow"
                                Data="@FilteredUsers"
                                AllowPaging="true" PageSize="8"
                                AllowSorting="true"
                                EditMode="DataGridEditMode.Single"
                                RowUpdate="@OnUserUpdate"
                                RowCreate="@OnUserCreate">

                    <Columns>
                        <RadzenDataGridColumn TItem="UserRow" Property="Name" Title="Name">
                            <EditTemplate Context="u">
                                <RadzenTextBox Style="width:100%" @bind-Value="u.Name" />
                            </EditTemplate>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="UserRow" Property="Email" Title="E-Mail">
                            <EditTemplate Context="u">
                                <RadzenTextBox Style="width:100%" @bind-Value="u.Email" />
                            </EditTemplate>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="UserRow" Property="Role" Title="Rolle" Width="170px">
                            <Template Context="u">
                                <RadzenBadge Text="@u.Role"
                                             Style="background: rgba(37,99,235,.10); color:#1e3a8a; border:1px solid rgba(17,24,39,.08);" />
                            </Template>
                            <EditTemplate Context="u">
                                <RadzenDropDown TValue="string" Data="@Roles" Style="width:100%" @bind-Value="u.Role" />
                            </EditTemplate>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="UserRow" Title="Aktionen" Width="230px">
                            <Template Context="u">
                                <div class="rowActions">
                                    <RadzenButton Size="ButtonSize.Small" Text="Bearbeiten" ButtonStyle="ButtonStyle.Light"
                                                  Click="@(() => BeginEditUser(u))" />
                                    <RadzenButton Size="ButtonSize.Small" Text="Löschen" ButtonStyle="ButtonStyle.Danger"
                                                  Click="@(() => DeleteUser(u))" />
                                </div>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>

            <!-- Stammdaten -->
            <div class="card">
                <div class="sectionHead">
                    
                    <div class="actions">
                        <div style="min-width:260px;">
                            <label class="fieldLabel">Stammdaten-Typ</label>
                            <RadzenDropDown TValue="string"
                                            Data="@MasterTypes"
                                            @bind-Value="@SelectedMasterType"
                                            Change="@OnMasterTypeChanged"
                                            Style="width:100%" />
                        </div>

                        <RadzenButton Text="Suchen" Icon="search" ButtonStyle="ButtonStyle.Primary" Click="@ReloadMaster" />
                    </div>
                </div>

                <div class="actions" style="margin-bottom:10px;">
                    <RadzenButton Text="Neuer Eintrag" Icon="add_circle" ButtonStyle="ButtonStyle.Success" Click="@AddMasterRow" />
                    <RadzenButton Text="Stammdaten → Clipboard" Icon="content_copy" ButtonStyle="ButtonStyle.Light" Click="@CopyMasterToClipboard" />
                    <RadzenButton Text="Stammdaten → CSV" Icon="download" ButtonStyle="ButtonStyle.Light" Click="@DownloadMasterCsv" />
                </div>

                <RadzenDataGrid @ref="_masterGrid"
                                TItem="MasterRow"
                                Data="@MasterRows"
                                AllowPaging="true" PageSize="8"
                                AllowSorting="true"
                                EditMode="DataGridEditMode.Single"
                                RowUpdate="@OnMasterUpdate"
                                RowCreate="@OnMasterCreate">

                    <Columns>
                        <RadzenDataGridColumn TItem="MasterRow" Property="Value" Title="Wert">
                            <EditTemplate Context="m">
                                <RadzenTextBox Style="width:100%" @bind-Value="m.Value" />
                            </EditTemplate>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="MasterRow" Title="Aktionen" Width="230px">
                            <Template Context="m">
                                <div class="rowActions">
                                    <RadzenButton Size="ButtonSize.Small" Text="Bearbeiten" ButtonStyle="ButtonStyle.Light"
                                                  Click="@(() => BeginEditMaster(m))" />
                                    <RadzenButton Size="ButtonSize.Small" Text="Löschen" ButtonStyle="ButtonStyle.Danger"
                                                  Click="@(() => DeleteMaster(m))" />
                                </div>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>

        </div>

    </div>
</div>

@code {
    private bool _jsReady;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var js = @"
(function(){
  window.invAdmin = window.invAdmin || {};
  window.invAdmin.copyText = async function(text){
    try{ await navigator.clipboard.writeText(text); }
    catch(e){
      const ta = document.createElement('textarea');
      ta.value = text; document.body.appendChild(ta);
      ta.select(); document.execCommand('copy'); ta.remove();
    }
  };
  window.invAdmin.downloadTextFile = function(fileName, mimeType, text){
    const blob = new Blob([text], { type: mimeType });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = fileName;
    document.body.appendChild(a); a.click(); a.remove();
    URL.revokeObjectURL(url);
  };
})();";
        await JS.InvokeVoidAsync("eval", js);
        _jsReady = true;
    }

    // --- Avatar menu ---
    private bool ShowMenu = false;
    private string CurrentUserName = "Herr Müller";
    private void ToggleMenu() => ShowMenu = !ShowMenu;

    private void Logout()
    {
        ShowMenu = false;
        NotificationService.Notify(NotificationSeverity.Info, "Abmeldung", "Du wurdest abgemeldet.");
        Nav.NavigateTo("/login");
    }

    // --- Users ---
    private RadzenDataGrid<UserRow>? _usersGrid;
    private readonly List<string> Roles = new() { "Lehrer", "Verantwortlicher", "Administrator" };

    private List<UserRow> Users = new()
    {
        new UserRow("Herr Müller", "mueller@schule.de", "Administrator"),
        new UserRow("Frau Schmidt", "schmidt@schule.de", "Verantwortlicher"),
        new UserRow("Herr Becker", "becker@schule.de", "Lehrer"),
        new UserRow("Frau Klein", "klein@schule.de", "Administrator"),
    };

    private string UserSearch = "";
    private string? UserRoleFilter = null;
    private List<UserRow> FilteredUsers = new();

    protected override void OnInitialized()
    {
        FilteredUsers = Users.ToList();
        LoadMasterSet();
    }

    private void ApplyUserFilter()
    {
        var q = UserSearch?.Trim().ToLowerInvariant() ?? "";
        FilteredUsers = Users
            .Where(u =>
                (string.IsNullOrEmpty(q) || u.Name.ToLowerInvariant().Contains(q) || u.Email.ToLowerInvariant().Contains(q)) &&
                (string.IsNullOrEmpty(UserRoleFilter) || u.Role == UserRoleFilter))
            .ToList();
    }

    private void AddUserRow()
    {
        var row = new UserRow("", "", "Lehrer");
        Users.Insert(0, row);
        ApplyUserFilter();
        _usersGrid?.EditRow(row);
    }

    private void BeginEditUser(UserRow u) => _usersGrid?.EditRow(u);

    private void DeleteUser(UserRow u)
    {
        Users.Remove(u);
        ApplyUserFilter();
        NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Gelöscht (Demo).");
    }

    private void OnUserUpdate(UserRow u)
    {
        if (string.IsNullOrWhiteSpace(u.Name) || string.IsNullOrWhiteSpace(u.Email))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Validierung", "Name und E-Mail dürfen nicht leer sein.");
            return;
        }
        NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Gespeichert (Demo).");
    }

    private void OnUserCreate(UserRow u)
    {
        NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Erstellt (Demo).");
    }

    // --- Master data ---
    private RadzenDataGrid<MasterRow>? _masterGrid;

    private readonly List<string> MasterTypes = new() { "Abteilungen", "Gruppen", "Fächer", "Orte", "Lehrer" };
    private string SelectedMasterType = "Abteilungen";

    private readonly Dictionary<string, List<string>> MasterStore = new()
    {
        ["Abteilungen"] = new() { "IT", "AV", "Metall", "Elektro" },
        ["Gruppen"] = new() { "EDV", "Lehr-Lernmittel" },
        ["Fächer"] = new() { "Mathe", "Physik", "Deutsch", "Informatik" },
        ["Orte"] = new() { "Raum 204", "Raum 110", "Lager" },
        ["Lehrer"] = new() { "Herr Müller", "Frau Schmidt", "Herr Becker" }
    };

    private List<MasterRow> MasterRows = new();

    private void OnMasterTypeChanged(object? _)
    {
        LoadMasterSet();
    }

    private void ReloadMaster()
    {
        LoadMasterSet();
        NotificationService.Notify(NotificationSeverity.Info, "Stammdaten", $"Typ geladen: {SelectedMasterType}");
    }

    private void LoadMasterSet()
    {
        MasterRows = MasterStore[SelectedMasterType].Select(v => new MasterRow { Value = v }).ToList();
    }

    private void PersistMasterSet()
    {
        MasterStore[SelectedMasterType] = MasterRows
            .Where(x => !string.IsNullOrWhiteSpace(x.Value))
            .Select(x => x.Value.Trim())
            .Distinct()
            .ToList();
    }

    private void AddMasterRow()
    {
        var row = new MasterRow { Value = "" };
        MasterRows.Insert(0, row);
        _masterGrid?.EditRow(row);
    }

    private void BeginEditMaster(MasterRow m) => _masterGrid?.EditRow(m);

    private void DeleteMaster(MasterRow m)
    {
        MasterRows.Remove(m);
        PersistMasterSet();
        NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Gelöscht (Demo).");
    }

    private void OnMasterUpdate(MasterRow m)
    {
        PersistMasterSet();
        NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Gespeichert (Demo).");
    }

    private void OnMasterCreate(MasterRow m)
    {
        PersistMasterSet();
        NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Erstellt (Demo).");
    }

    // --- Export helpers ---
    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "??";
        if (parts.Length == 1) return new string(parts[0].Take(2).ToArray()).ToUpperInvariant();
        return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}";
    }

    private string UsersToCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Name;Email;Role");
        foreach (var u in FilteredUsers)
        {
            sb.AppendLine($"{Clean(u.Name)};{Clean(u.Email)};{Clean(u.Role)}");
        }
        return sb.ToString();
    }

    private string MasterToCsv(string type)
    {
        var sb = new StringBuilder();
        sb.AppendLine("Typ;Wert");
        foreach (var v in MasterStore[type])
        {
            sb.AppendLine($"{Clean(type)};{Clean(v)}");
        }
        return sb.ToString();
    }

    private static string Clean(string s)
        => (s ?? "")
            .Replace(";", ",")
            .Replace("\n", " ")
            .Replace("\r", " ")
            .Trim();

    private async Task CopyUsersToClipboard()
    {
        if (!_jsReady)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Export", "JS nicht bereit.");
            return;
        }
        await JS.InvokeVoidAsync("invAdmin.copyText", UsersToCsv());
        NotificationService.Notify(NotificationSeverity.Success, "Export", "Admins in Zwischenablage kopiert.");
    }

    private async Task DownloadUsersCsv()
    {
        if (!_jsReady)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Export", "JS nicht bereit.");
            return;
        }
        var csv = UsersToCsv();
        await JS.InvokeVoidAsync("invAdmin.downloadTextFile", "admins.csv", "text/csv;charset=utf-8", csv);
        NotificationService.Notify(NotificationSeverity.Info, "Export", "CSV Download gestartet.");
    }

    private async Task CopyMasterToClipboard()
    {
        if (!_jsReady)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Export", "JS nicht bereit.");
            return;
        }
        await JS.InvokeVoidAsync("invAdmin.copyText", MasterToCsv(SelectedMasterType));
        NotificationService.Notify(NotificationSeverity.Success, "Export", "Stammdaten in Zwischenablage kopiert.");
    }

    private async Task DownloadMasterCsv()
    {
        if (!_jsReady)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Export", "JS nicht bereit.");
            return;
        }
        var csv = MasterToCsv(SelectedMasterType);
        await JS.InvokeVoidAsync("invAdmin.downloadTextFile", $"stammdaten_{SelectedMasterType}.csv", "text/csv;charset=utf-8", csv);
        NotificationService.Notify(NotificationSeverity.Info, "Export", "CSV Download gestartet.");
    }

    // --- DTOs ---
    public sealed class MasterRow
    {
        public string Value { get; set; } = "";
    }

    public sealed class UserRow
    {
        public UserRow() { }
        public UserRow(string name, string email, string role)
        {
            Name = name;
            Email = email;
            Role = role;
        }
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "Lehrer";
    }
}