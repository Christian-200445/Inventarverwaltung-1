@page "/Home"
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AppDbContext Db
@using Inventarverwaltung1.Data
@using Microsoft.EntityFrameworkCore
@using System.Text

<style>
    :root {
        --bg: #f3f5f9;
        --card: #ffffff;
        --muted: #6b7280;
        --text: #111827;
        --line: rgba(17,24,39,.10);
        --shadow: 0 16px 40px rgba(17,24,39,.10);
        --shadow2: 0 10px 24px rgba(17,24,39,.08);
        --blue1: #1E3A8A;
        --blue2: #3B82F6;
        --blue3: #59a7ff;
        --radius: 18px;
    }

    * { box-sizing: border-box; }

    .iv-page {
        width: 100%;
        min-height: 100vh;
        background: radial-gradient(1200px 520px at 50% -120px, rgba(89,167,255,.22), transparent 70%),
                    radial-gradient(900px 420px at 85% 0px, rgba(47,99,230,.14), transparent 55%),
                    linear-gradient(#ffffff, var(--bg));
        padding: 20px;
    }

    .iv-header {
        width: 100%; height: 95px;
        background: linear-gradient(90deg, var(--blue1), var(--blue2));
        color: white; border-radius: 18px; margin-bottom: 18px;
        box-shadow: var(--shadow); display: flex; align-items: center;
        padding: 0 25px; gap: 20px; position: relative;
    }
    .iv-header img { height: 56px; width: auto; z-index: 1; }
    .iv-header h1 {
        margin: 0; font-size: 34px; font-weight: 700;
        flex-grow: 1; text-align: center; letter-spacing: 0.5px; z-index: 1;
    }

    .iv-user {
        position: absolute; right: 18px; top: 50%;
        transform: translateY(-50%); display: flex; align-items: center; z-index: 5;
    }
    .iv-avatar {
        width: 42px; height: 42px; border-radius: 999px;
        border: 1px solid rgba(255,255,255,.25); background: rgba(255,255,255,.18);
        color: #fff; font-weight: 900; cursor: pointer;
        box-shadow: 0 10px 18px rgba(0,0,0,.12);
        display: grid; place-items: center; user-select: none;
    }
    .iv-menu {
        position: fixed; top: 110px; right: 38px; width: 180px;
        background: #fff; border: 1px solid rgba(0,0,0,.10);
        border-radius: 14px; box-shadow: 0 14px 36px rgba(0,0,0,.12);
        padding: 10px; z-index: 999999;
    }
    .iv-menu-name { font-weight: 900; color: #111827; }
    .iv-menu-sub { font-size: 12px; color: #6b7280; margin-bottom: 10px; }
    .iv-menu-admin {
        width: 100%; border: none; border-radius: 12px;
        padding: 10px 12px; cursor: pointer; font-weight: 800;
        background: #1d4ed8; color: white; margin-bottom: 8px;
    }
    .iv-logout {
        width: 100%; border: none; border-radius: 12px;
        padding: 10px 12px; cursor: pointer; font-weight: 800;
        background: #ef4444; color: white;
    }

    .iv-content {
        width: 100%; background: var(--card); padding: 16px;
        border-radius: var(--radius); box-shadow: var(--shadow2);
        border: 1px solid var(--line);
    }

    .iv-toolbar {
        display: flex; gap: 12px; flex-wrap: wrap;
        align-items: center; justify-content: space-between; margin-bottom: 12px;
    }
    .iv-toolbar-left { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }

    .iv-btn {
        border: none; border-radius: 12px; padding: 10px 14px;
        font-weight: 800; cursor: pointer;
        box-shadow: 0 8px 18px rgba(17,24,39,.08);
        background: #2563eb; color: #fff;
        display: flex; align-items: center; gap: 8px;
    }
    .iv-btn.green { background: #16a34a; }
    .iv-btn.red   { background: #ef4444; }
    .iv-btn.gray  { background: #6b7280; }

    .iv-overlay {
        position: fixed; inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 10000;
        display: flex; align-items: center; justify-content: center;
    }
    .iv-modal {
        background: #fff; border-radius: 18px;
        padding: 28px; width: 520px; max-width: 95vw;
        box-shadow: 0 24px 60px rgba(0,0,0,.18);
        max-height: 90vh; overflow-y: auto;
    }
    .iv-modal h2 { margin: 0 0 20px 0; font-size: 20px; color: #111827; }

    .iv-form-group { margin-bottom: 14px; display: flex; flex-direction: column; gap: 5px; }
    .iv-form-group label { font-weight: 700; font-size: 13px; color: #374151; }
    .iv-form-group input,
    .iv-form-group select,
    .iv-form-group textarea {
        border: 1px solid #d1d5db; border-radius: 10px;
        padding: 9px 12px; font-size: 14px; outline: none; transition: border .2s;
    }
    .iv-form-group input:focus,
    .iv-form-group select:focus,
    .iv-form-group textarea:focus { border-color: #3b82f6; }

    .iv-modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }

    .iv-confirm {
        background: #fff; border-radius: 16px; padding: 28px;
        width: 360px; max-width: 95vw;
        box-shadow: 0 24px 60px rgba(0,0,0,.18); text-align: center;
    }
    .iv-confirm p { margin: 0 0 20px 0; font-size: 15px; color: #374151; }

    .iv-badge {
        display: inline-block; padding: 4px 10px; border-radius: 999px;
        font-weight: 800; font-size: 12px; color: #fff; white-space: nowrap;
    }
    .s-neu          { background: #3b82f6; }
    .s-gut          { background: #10b981; }
    .s-defekt       { background: #ef4444; }
    .s-ausgemustert { background: #6b7280; }
    .s-ausgeliehen  { background: #f97316; } /* Orange */
    .s-verfuegbar   { background: #16a34a; } /* Grün */
</style>

<div class="iv-page" @onclick="CloseMenu">

    <!-- Header -->
    <div class="iv-header" @onclick:stopPropagation="true">
        <img src="logo_header.jpg" />
        <h1>Inventar</h1>
        <div class="iv-user" @onclick:stopPropagation="true">
            <div class="iv-avatar" @onclick="ToggleMenu">User</div>
            @if (_menuOpen)
            {
                <div class="iv-menu">
                    <div class="iv-menu-name">@_angemeldeterName</div>
                    <div class="iv-menu-sub">@_angemeldeteRolle</div>

                    @* Admin Button - nur für Admins sichtbar *@
                    @if (_istAdmin)
                    {
                        <button class="iv-menu-admin" type="button" @onclick="ZurAdminSeite">
                            ⚙️ Admin
                        </button>
                    }

                    <button class="iv-logout" type="button" @onclick="Logout">Logout</button>
                </div>
            }
        </div>
    </div>

    <!-- Tabelle -->
    <div class="iv-content">
        <div class="iv-toolbar">
            <div class="iv-toolbar-left">
                <button class="iv-btn green" type="button" @onclick="OpenAddDialog">
                    + Hinzufügen
                </button>
                <button class="iv-btn" type="button" @onclick="DownloadInventoryCsv">
                    Inventar → CSV
                </button>
            </div>
            <div style="color: var(--muted); font-size: 12px;">
                Tipp: Filter findest du oben in den Spalten (Trichter).
            </div>
        </div>

        <RadzenDataGrid Data="@_items"
                        TItem="InventarViewModel"
                        AllowFiltering="true"
                        FilterPopupRenderMode="PopupRenderMode.OnDemand"
                        FilterMode="FilterMode.Advanced"
                        AllowColumnResize="true"
                        AllowPaging="true"
                        AllowSorting="true"
                        Style="width: 100%;">
            <Columns>
                <RadzenDataGridColumn TItem="InventarViewModel" Property="Bezeichnung"       Title="Bezeichnung" />
                <RadzenDataGridColumn TItem="InventarViewModel" Property="Seriennummer"      Title="Seriennummer" />
                <RadzenDataGridColumn TItem="InventarViewModel" Property="Anschaffungsdatum" Title="Anschaffungsdatum">
                    <Template>@context.Anschaffungsdatum?.ToString("dd.MM.yyyy")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="InventarViewModel" Property="Gruppe"  Title="Gruppe" />
                <RadzenDataGridColumn TItem="InventarViewModel" Property="Zustand" Title="Zustand">
                    <Template>
                        <span class="iv-badge @ZustandToClass(context.Zustand)">@context.Zustand</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="InventarViewModel" Property="Ort"       Title="Ort" />
                <RadzenDataGridColumn TItem="InventarViewModel" Property="Bemerkung" Title="Bemerkung" />

                <RadzenDataGridColumn TItem="InventarViewModel" Property="AusgeliehenVon" Title="Ausgeliehen von">
                    <Template>
                        @if (!string.IsNullOrEmpty(context.AusgeliehenVon))
                        {
                            <span class="iv-badge s-ausgeliehen">@context.AusgeliehenVon</span>
                        }
                        else
                        {
                            <span class="iv-badge s-verfuegbar">Verfügbar</span>
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="InventarViewModel" Title="Aktionen" Filterable="false" Sortable="false">
                    <Template>
                        <button class="iv-btn" style="padding:6px 10px; font-size:12px;"
                                @onclick="() => OpenEditDialog(context)">✏️ Bearbeiten</button>
                        <button class="iv-btn red" style="padding:6px 10px; font-size:12px; margin-left:6px;"
                                @onclick="() => OpenDeleteConfirm(context)">🗑 Löschen</button>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
</div>

<!-- Hinzufügen / Bearbeiten Dialog -->
@if (_showDialog)
{
    <div class="iv-overlay" @onclick="CloseDialog">
        <div class="iv-modal" @onclick:stopPropagation="true">
            <h2>@(_editMode ? "Inventargegenstand bearbeiten" : "Inventargegenstand hinzufügen")</h2>

            <div class="iv-form-group">
                <label>Bezeichnung *</label>
                <input @bind="_form.Bezeichnung" placeholder="z.B. Laptop Dell" />
            </div>
            <div class="iv-form-group">
                <label>Seriennummer *</label>
                <input @bind="_form.Seriennummer" placeholder="z.B. SN-001" />
            </div>
            <div class="iv-form-group">
                <label>Anschaffungsdatum</label>
                <input type="date" @bind="_form.Anschaffungsdatum" />
            </div>
            <div class="iv-form-group">
                <label>Beschreibung</label>
                <textarea @bind="_form.Beschreibung" rows="2"></textarea>
            </div>
            <div class="iv-form-group">
                <label>Bemerkung</label>
                <textarea @bind="_form.Bemerkung" rows="2"></textarea>
            </div>
            <div class="iv-form-group">
                <label>Gruppe</label>
                <select @bind="_form.GruppeId">
                    <option value="">-- Bitte wählen --</option>
                    @foreach (var g in _gruppen)
                    {
                        <option value="@g.Id">@g.Name</option>
                    }
                </select>
            </div>
            <div class="iv-form-group">
                <label>Zustand</label>
                <select @bind="_form.ZustandId">
                    <option value="">-- Bitte wählen --</option>
                    @foreach (var z in _zustaende)
                    {
                        <option value="@z.Id">@z.Beschreibung</option>
                    }
                </select>
            </div>
            <div class="iv-form-group">
                <label>Ort</label>
                <select @bind="_form.OrtId">
                    <option value="">-- Kein Ort --</option>
                    @foreach (var o in _orte)
                    {
                        <option value="@o.Id">Regal @o.RegalNr – @o.RegalOrt</option>
                    }
                </select>
            </div>
            <div class="iv-form-group">
                <label>Ausgeliehen von</label>
                <select @bind="_form.BenutzerID">
                    <option value="">-- Nicht ausgeliehen --</option>
                    @foreach (var b in _benutzer)
                    {
                        <option value="@b.Id">@b.Vorname @b.Nachname</option>
                    }
                </select>
            </div>

            @if (!string.IsNullOrEmpty(_errorMsg))
            {
                <p style="color:#ef4444; font-weight:700;">@_errorMsg</p>
            }

            <div class="iv-modal-actions">
                <button class="iv-btn gray" type="button" @onclick="CloseDialog">Abbrechen</button>
                <button class="iv-btn green" type="button" @onclick="SaveItem">
                    @(_editMode ? "Speichern" : "Hinzufügen")
                </button>
            </div>
        </div>
    </div>
}

<!-- Löschen Bestätigung -->
@if (_showConfirm)
{
    <div class="iv-overlay">
        <div class="iv-confirm">
            <p>Möchtest du <strong>@_deleteTarget?.Bezeichnung</strong> wirklich löschen?</p>
            <div style="display:flex; gap:10px; justify-content:center;">
                <button class="iv-btn gray" type="button" @onclick="() => _showConfirm = false">Abbrechen</button>
                <button class="iv-btn red"  type="button" @onclick="DeleteItem">Löschen</button>
            </div>
        </div>
    </div>
}

@code {
    // ──────────────────────────────────────────────
    // ViewModel
    // ──────────────────────────────────────────────
    private class InventarViewModel
    {
        public Guid      Id                { get; set; }
        public string?   Bezeichnung       { get; set; }
        public string?   Seriennummer      { get; set; }
        public DateTime? Anschaffungsdatum { get; set; }
        public string?   Beschreibung      { get; set; }
        public string?   Bemerkung         { get; set; }
        public string?   Gruppe            { get; set; }
        public string?   Zustand           { get; set; }
        public string?   Ort               { get; set; }
        public string?   AusgeliehenVon    { get; set; }
    }

    private class InventarForm
    {
        public Guid      Id                { get; set; }
        public string    Bezeichnung       { get; set; } = "";
        public string    Seriennummer      { get; set; } = "";
        public DateTime? Anschaffungsdatum { get; set; }
        public string    Beschreibung      { get; set; } = "";
        public string    Bemerkung         { get; set; } = "";
        public Guid?     GruppeId          { get; set; }
        public Guid?     ZustandId         { get; set; }
        public Guid?     OrtId             { get; set; }
        public Guid?     BenutzerID        { get; set; }
    }

    // ──────────────────────────────────────────────
    // State
    // ──────────────────────────────────────────────
    private List<InventarViewModel> _items     = new();
    private List<Gruppe>            _gruppen   = new();
    private List<Zustand>           _zustaende = new();
    private List<Ort>               _orte      = new();
    private List<Benutzer>          _benutzer  = new();

    private bool              _menuOpen       = false;
    private bool              _showDialog     = false;
    private bool              _showConfirm    = false;
    private bool              _editMode       = false;
    private string?           _errorMsg;
    private InventarForm      _form           = new();
    private InventarViewModel? _deleteTarget;

    // Angemeldeter Benutzer
    private string _angemeldeterName  = "User";
    private string _angemeldeteRolle  = "";
    private bool   _istAdmin          = false;

    // ──────────────────────────────────────────────
    // Laden
    // ──────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _gruppen   = await Db.Gruppe.ToListAsync();
        _zustaende = await Db.Zustand.ToListAsync();
        _orte      = await Db.Ort.ToListAsync();
        _benutzer  = await Db.Benutzer.ToListAsync();
        await LoadItems();

        // TODO: Hier später den eingeloggten Benutzer laden
        // Temporär: ersten Admin aus der DB holen zum Testen
        var admin = await Db.Benutzer
            .Include(b => b.Rolle)
            .FirstOrDefaultAsync(b => b.Rolle != null && b.Rolle.Name == "Admin");

        if (admin != null)
        {
            _angemeldeterName = $"{admin.Vorname} {admin.Nachname}";
            _angemeldeteRolle = admin.Rolle?.Name ?? "";
            _istAdmin         = admin.Rolle?.Name?.ToLower() == "admin";
        }
    }

    private async Task LoadItems()
    {
        _items = await Db.Inventargegenstand
            .Include(i => i.Gruppe)
            .Include(i => i.Zustand)
            .Include(i => i.Ort)
            .Include(i => i.Benutzer)
            .Select(i => new InventarViewModel
            {
                Id                = i.Id,
                Bezeichnung       = i.Bezeichnung,
                Seriennummer      = i.Seriennummer,
                Anschaffungsdatum = i.Anschaffungsdatum,
                Beschreibung      = i.Beschreibung,
                Bemerkung         = i.Bemerkung,
                Gruppe            = i.Gruppe  != null ? i.Gruppe.Name                          : "-",
                Zustand           = i.Zustand != null ? i.Zustand.Beschreibung                 : "-",
                Ort               = i.Ort     != null ? $"Regal {i.Ort.RegalNr} – {i.Ort.RegalOrt}" : "-",
                AusgeliehenVon    = i.Benutzer != null
                    ? i.Benutzer.Vorname + " " + i.Benutzer.Nachname
                    : null
            })
            .ToListAsync();
    }

    // ──────────────────────────────────────────────
    // Dialog
    // ──────────────────────────────────────────────
    private void OpenAddDialog()
    {
        _form       = new InventarForm();
        _editMode   = false;
        _errorMsg   = null;
        _showDialog = true;
    }

    private void OpenEditDialog(InventarViewModel item)
    {
        var entity = Db.Inventargegenstand.Find(item.Id);
        if (entity is null) return;

        _form = new InventarForm
        {
            Id                = entity.Id,
            Bezeichnung       = entity.Bezeichnung   ?? "",
            Seriennummer      = entity.Seriennummer  ?? "",
            Anschaffungsdatum = entity.Anschaffungsdatum,
            Beschreibung      = entity.Beschreibung  ?? "",
            Bemerkung         = entity.Bemerkung     ?? "",
            GruppeId          = entity.GruppeId,
            ZustandId         = entity.ZustandId,
            OrtId             = entity.OrtId,
            BenutzerID        = entity.BenutzerID
        };
        _editMode   = true;
        _errorMsg   = null;
        _showDialog = true;
    }

    private void CloseDialog() => _showDialog = false;

    private void OpenDeleteConfirm(InventarViewModel item)
    {
        _deleteTarget = item;
        _showConfirm  = true;
    }

    // ──────────────────────────────────────────────
    // Speichern
    // ──────────────────────────────────────────────
    private async Task SaveItem()
    {
        if (string.IsNullOrWhiteSpace(_form.Bezeichnung) ||
            string.IsNullOrWhiteSpace(_form.Seriennummer))
        {
            _errorMsg = "Bezeichnung und Seriennummer sind Pflichtfelder!";
            return;
        }

        if (_editMode)
        {
            var entity = await Db.Inventargegenstand.FindAsync(_form.Id);
            if (entity is not null)
            {
                entity.Bezeichnung       = _form.Bezeichnung;
                entity.Seriennummer      = _form.Seriennummer;
                entity.Anschaffungsdatum = _form.Anschaffungsdatum;
                entity.Beschreibung      = _form.Beschreibung;
                entity.Bemerkung         = _form.Bemerkung;
                entity.GruppeId          = _form.GruppeId;
                entity.ZustandId         = _form.ZustandId;
                entity.OrtId             = _form.OrtId;
                entity.BenutzerID        = _form.BenutzerID;
            }
        }
        else
        {
            var entity = new Inventargegenstand
            {
                Id                = Guid.NewGuid(),
                Bezeichnung       = _form.Bezeichnung,
                Seriennummer      = _form.Seriennummer,
                Anschaffungsdatum = _form.Anschaffungsdatum,
                Beschreibung      = _form.Beschreibung,
                Bemerkung         = _form.Bemerkung,
                GruppeId          = _form.GruppeId,
                ZustandId         = _form.ZustandId,
                OrtId             = _form.OrtId,
                BenutzerID        = _form.BenutzerID
            };
            Db.Inventargegenstand.Add(entity);
        }

        await Db.SaveChangesAsync();
        await LoadItems();
        _showDialog = false;
    }

    // ──────────────────────────────────────────────
    // Löschen
    // ──────────────────────────────────────────────
    private async Task DeleteItem()
    {
        if (_deleteTarget is null) return;
        var entity = await Db.Inventargegenstand.FindAsync(_deleteTarget.Id);
        if (entity is not null)
        {
            Db.Inventargegenstand.Remove(entity);
            await Db.SaveChangesAsync();
        }
        _showConfirm  = false;
        _deleteTarget = null;
        await LoadItems();
    }

    // ──────────────────────────────────────────────
    // Hilfsfunktionen
    // ──────────────────────────────────────────────
    private void ToggleMenu()     => _menuOpen = !_menuOpen;
    private void CloseMenu()      => _menuOpen  = false;
    private void ZurAdminSeite()  => Nav.NavigateTo("/admin", true);
    private void Logout()
    {
        _menuOpen = false;
        Nav.NavigateTo("/login", true);
    }

    private static string ZustandToClass(string? z) => z?.ToLower() switch
    {
        "neu"    => "s-neu",
        "gut"    => "s-gut",
        "defekt" => "s-defekt",
        _        => "s-ausgemustert"
    };

    private async Task DownloadInventoryCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Bezeichnung;Seriennummer;Anschaffungsdatum;Gruppe;Zustand;Ort;Bemerkung;AusgeliehenVon");
        foreach (var i in _items)
            sb.AppendLine($"{i.Bezeichnung};{i.Seriennummer};{i.Anschaffungsdatum:dd.MM.yyyy};{i.Gruppe};{i.Zustand};{i.Ort};{i.Bemerkung};{i.AusgeliehenVon}");

        await JS.InvokeVoidAsync("eval", @"
            window.dlCsv = function(name, text){
                const b = new Blob([text],{type:'text/csv;charset=utf-8'});
                const u = URL.createObjectURL(b);
                const a = document.createElement('a');
                a.href=u; a.download=name;
                document.body.appendChild(a); a.click(); a.remove();
                URL.revokeObjectURL(u);
            }");
        await JS.InvokeVoidAsync("dlCsv", "inventar.csv", sb.ToString());
    }
}
