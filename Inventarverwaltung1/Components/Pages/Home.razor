@page "/hauptmenu"

<style>
    /* ===== PAGE ===== */
    .iv-page {
        min-height: 100vh;
        background: #f3f5f9;
        padding-bottom: 30px;
    }

    /* ===== HEADER ===== */
    .iv-header {
        max-width: 1200px;
        margin: 20px auto 30px;
        border-radius: 18px;
        background: linear-gradient(90deg, #1f4ea8, #2a64d6);
        box-shadow: 0 12px 28px rgba(0,0,0,.18);
    }

    .iv-header-inner {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 18px 26px;
    }

    .iv-logo {
        height: 60px;
    }

    .iv-title {
        flex: 1;
        text-align: center;
        color: white;
        font-size: 42px;
        font-weight: 900;
    }

    /* ===== CARD ===== */
    .iv-card {
        max-width: 1200px;
        margin: 0 auto;
        background: white;
        border-radius: 18px;
        padding: 20px;
        box-shadow: 0 14px 36px rgba(0,0,0,.12);
    }

    /* Radzen Grid schöner */
    .rz-datatable {
        border-radius: 12px;
    }
</style>

<div class="iv-page">

    <!-- HEADER -->
    <div class="iv-header">
        <div class="iv-header-inner">
            <img src="logo_header.jpg" class="iv-logo" />
            <div class="iv-title">Inventarverwaltung</div>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="iv-card">

        <RadzenDataGrid @bind-Value="@selectedItems"
                        Data="@data"
                        TItem="IDictionary<string, object>"
                        AllowFiltering="true"
                        AllowPaging="true"
                        AllowSorting="true"
                        ColumnWidth="auto"
                        Style="width:100%;">

            <Columns>
                @foreach (var column in columns)
                {
                    <RadzenDataGridColumn Title="@column.Key"
                                          Type="@column.Value"
                                          Property="@PropertyAccess.GetDynamicPropertyExpression(column.Key, column.Value)">
                        <Template>
                            @context[@column.Key]
                        </Template>
                    </RadzenDataGridColumn>
                }
            </Columns>

        </RadzenDataGrid>

    </div>

</div>

@code {

    IList<IDictionary<string, object>> selectedItems;
    public IEnumerable<IDictionary<string, object>> data { get; set; }
    public IDictionary<string, Type> columns { get; set; }

    protected override void OnInitialized()
    {
        columns = new Dictionary<string, Type>()
        {
            { "InventarID", typeof(int) },
            { "Name", typeof(string) },
            { "Status", typeof(string) },
            { "Abteilung", typeof(string) },
            { "Gruppe", typeof(string) },
            { "Schulfach", typeof(string) },
            { "Ort", typeof(string) },
            { "Verantwortlich", typeof(string) },
            { "Rolle", typeof(string) },
            { "Zustand", typeof(string) }
        };

        data = new List<Dictionary<string, object>>
        {
            new()
            {
