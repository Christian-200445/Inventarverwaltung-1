@* ============================================================
   Admin.razor – Admin-Dashboard der Inventarverwaltung
   Funktionen: Benutzerverwaltung + Stammdaten-Pflege
   ============================================================ *@

@page "/Admin"

@using Inventarverwaltung1.Data
@using Microsoft.EntityFrameworkCore
@using Radzen
@using Radzen.Blazor
@using System.Text
@using BCryptNet = global::BCrypt.Net.BCrypt   @* Alias damit kein Namespace-Konflikt *@

@inject IDbContextFactory<AppDbContext> DbFactory
@inject NotificationService NotificationService
@inject IJSRuntime JS
@inject NavigationManager Nav

<style>
    :root {
        --bg: #f3f5f9; --card: #ffffff; --muted: #6b7280; --text: #111827;
        --blue1: #122b73; --blue2: #2f63e6; --blue3: #59a7ff; --radius: 20px;
        --shadow: 0 16px 40px rgba(17,24,39,.10); --line: rgba(17,24,39,.10);
    }
    * { box-sizing: border-box; }
    .page { min-height:100vh; background:linear-gradient(#ffffff,var(--bg)); padding:22px 18px 60px; font-family:system-ui,sans-serif; color:var(--text); }
    .wrap { max-width:1320px; margin:0 auto; }
    .top  { border-radius:26px; padding:16px; min-height:92px; background:linear-gradient(95deg,var(--blue1),var(--blue2) 55%,var(--blue3)); box-shadow:var(--shadow); color:#fff; display:flex; align-items:center; justify-content:space-between; gap:14px; }
    .title { font-size:22px; font-weight:900; }
    .iv-avatar { width:42px; height:42px; border-radius:999px; background:rgba(255,255,255,.18); color:#fff; font-weight:900; cursor:pointer; display:grid; place-items:center; }
    .iv-menu { position:fixed; top:110px; right:38px; width:180px; background:#fff; border:1px solid rgba(0,0,0,.10); border-radius:14px; box-shadow:0 14px 36px rgba(0,0,0,.12); padding:10px; z-index:999999; }
    .iv-logout { width:100%; border:none; border-radius:12px; padding:10px 12px; cursor:pointer; font-weight:800; background:#ef4444; color:white; }
    .kpis { margin-top:16px; display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:14px; }
    .kpi  { background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:14px; }
    .kpi .label { font-size:12px; color:var(--muted); }
    .kpi .value { font-size:26px; font-weight:900; margin-top:6px; }
    .kpiIcon { width:38px; height:38px; border-radius:16px; display:grid; place-items:center; background:rgba(47,99,230,.10); font-size:18px; }
    .grid { margin-top:14px; display:grid; grid-template-columns:1fr 1fr; gap:14px; }
    .card { background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:14px; }
    .fieldLabel { display:block; font-size:12px; color:var(--muted); margin:0 0 4px 2px; }
    .actions    { display:flex; gap:10px; flex-wrap:wrap; align-items:flex-end; }
    .rowActions { display:flex; gap:6px; flex-wrap:wrap; }

    /* ── Passwort-Modal-Overlay ── */
    .pw-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,.45);
        display: flex; align-items: center; justify-content: center;
        z-index: 99999;
    }
    .pw-modal {
        background: #fff; border-radius: 20px;
        box-shadow: 0 24px 60px rgba(0,0,0,.20);
        padding: 28px 28px 22px; width: 380px; max-width: 95vw;
    }
    .pw-modal-title {
        font-size: 17px; font-weight: 900; color: var(--blue1);
        margin: 0 0 4px;
    }
    .pw-modal-sub {
        font-size: 12px; color: var(--muted); margin: 0 0 20px;
    }
    .pw-field { margin-bottom: 14px; }
    .pw-field label { display:block; font-size:12px; font-weight:700; color:var(--muted); margin-bottom:5px; }
    .pw-field input {
        width: 100%; padding: 10px 12px; border-radius: 10px;
        border: 1px solid rgba(0,0,0,.18); font-size: 14px;
        outline: none; background: #f9fafc;
    }
    .pw-field input:focus { border-color: var(--blue2); box-shadow: 0 0 0 3px rgba(47,99,230,.12); }
    .pw-actions { display:flex; gap:10px; margin-top: 6px; }
    .pw-btn-save {
        flex: 1; padding: 10px; border: none; border-radius: 10px;
        background: var(--blue2); color: #fff; font-weight: 800;
        font-size: 14px; cursor: pointer;
    }
    .pw-btn-save:hover { filter: brightness(1.08); }
    .pw-btn-cancel {
        padding: 10px 16px; border: 1px solid rgba(0,0,0,.15);
        border-radius: 10px; background: #fff; font-weight: 700;
        font-size: 14px; cursor: pointer; color: var(--muted);
    }
    .pw-btn-cancel:hover { background: #f3f4f6; }
    .pw-error { font-size: 12px; color: #b42318; margin-top: 8px; font-weight: 700; }

    @@media (max-width:980px) { .kpis { grid-template-columns:1fr 1fr; } .grid { grid-template-columns:1fr; } }
    @@media (max-width:520px) { .kpis { grid-template-columns:1fr; } }
</style>

<div class="page">
 <div class="wrap">

  @* ── HEADER ── *@
  <div class="top">
   <div class="title">Admin-Dashboard</div>
   <div style="position:relative">
    <div class="iv-avatar" @onclick="ToggleMenu">@GetInitials(CurrentUserName)</div>
    @if (ShowMenu)
    {
     <div class="iv-menu">
      <div style="font-weight:900">@CurrentUserName</div>
      <div style="font-size:12px;color:#6b7280;margin-bottom:10px">Rolle: Administrator</div>
      <button class="iv-logout" @onclick="Logout">Abmelden</button>
     </div>
    }
   </div>
  </div>

  @* ── KPI-KACHELN ── *@
  <div class="kpis">
   <div class="kpi"><div style="display:flex;justify-content:space-between"><div><div class="label">Nutzer gesamt</div><div class="value">@Users.Count</div></div><div class="kpiIcon">👤</div></div></div>
   <div class="kpi"><div style="display:flex;justify-content:space-between"><div><div class="label">Angezeigt</div><div class="value">@FilteredUsers.Count</div></div><div class="kpiIcon">✅</div></div></div>
   <div class="kpi"><div style="display:flex;justify-content:space-between"><div><div class="label">Stammdaten-Typ</div><div class="value" style="font-size:16px;margin-top:8px">@SelectedMasterType</div></div><div class="kpiIcon">📚</div></div></div>
   <div class="kpi"><div style="display:flex;justify-content:space-between"><div><div class="label">Einträge</div><div class="value">@FilteredMasterRows.Count</div></div><div class="kpiIcon">🧾</div></div></div>
  </div>

  <div class="grid">

   @* ─────────── BENUTZERVERWALTUNG ─────────── *@
   <div class="card">
    <div class="actions" style="margin-bottom:10px">
     <div style="min-width:240px">
      <label class="fieldLabel">Suche (Name / E-Mail)</label>
      <RadzenTextBox Style="width:100%" @bind-Value="UserSearch"
       @oninput="@(e => { UserSearch = e.Value?.ToString() ?? ""; ApplyUserFilter(); })" />
     </div>
     <RadzenButton Text="Neuer Benutzer" Icon="person_add" ButtonStyle="ButtonStyle.Success" Click="AddUserRow" />
     <RadzenButton Text="→ CSV" Icon="download" ButtonStyle="ButtonStyle.Light" Click="DownloadUsersCsv" />
    </div>

    <RadzenDataGrid @ref="_usersGrid" TItem="UserRow" Data="FilteredUsers"
                    AllowPaging="true" PageSize="8" AllowSorting="true"
                    EditMode="DataGridEditMode.Single"
                    RowUpdate="OnUserUpdate" RowCreate="OnUserCreate">
     <Columns>
      <RadzenDataGridColumn TItem="UserRow" Property="Vorname" Title="Vorname">
       <EditTemplate Context="u"><RadzenTextBox Style="width:100%" @bind-Value="u.Vorname" /></EditTemplate>
      </RadzenDataGridColumn>
      <RadzenDataGridColumn TItem="UserRow" Property="Nachname" Title="Nachname">
       <EditTemplate Context="u"><RadzenTextBox Style="width:100%" @bind-Value="u.Nachname" /></EditTemplate>
      </RadzenDataGridColumn>
      <RadzenDataGridColumn TItem="UserRow" Property="Mail" Title="E-Mail">
       <EditTemplate Context="u"><RadzenTextBox Style="width:100%" @bind-Value="u.Mail" /></EditTemplate>
      </RadzenDataGridColumn>

      @* Passwort: im Lesemodus Punkte, im Editmodus nur bei neuer Zeile ein Eingabefeld *@
      <RadzenDataGridColumn TItem="UserRow" Title="Passwort" Width="130px">
       <Template Context="u">
        <span style="color:var(--muted);letter-spacing:2px">••••••</span>
       </Template>
       <EditTemplate Context="u">
        @if (u.Id == Guid.Empty)
        {
         @* Guid.Empty = neue Zeile → Passwort setzen *@
         <RadzenTextBox Style="width:100%" @bind-Value="u.NeuesPasswort" Placeholder="mind. 6 Zeichen" />
        }
        else
        {
         <span style="font-size:11px;color:var(--muted)">via 🔑</span>
        }
       </EditTemplate>
      </RadzenDataGridColumn>

      <RadzenDataGridColumn TItem="UserRow" Title="Aktionen" Width="200px">
       <Template Context="u">
        <div class="rowActions">
         <RadzenButton Size="ButtonSize.Small" Text="Bearb." Icon="edit"   ButtonStyle="ButtonStyle.Light"  Click="@(() => StartEditUser(u))" />
         <RadzenButton Size="ButtonSize.Small" Icon="key"                   ButtonStyle="ButtonStyle.Info"   Click="@(() => OpenPasswordModal(u))" title="Passwort ändern" />
         <RadzenButton Size="ButtonSize.Small" Icon="delete"                ButtonStyle="ButtonStyle.Danger" Click="@(() => DeleteUser(u))" />
        </div>
       </Template>
       <EditTemplate Context="u">
        <div class="rowActions">
         <RadzenButton Size="ButtonSize.Small" Text="Speichern" Icon="save"   ButtonStyle="ButtonStyle.Success" Click="@(() => SaveUser(u))" />
         <RadzenButton Size="ButtonSize.Small" Text="Abbruch"   Icon="cancel" ButtonStyle="ButtonStyle.Light"   Click="@(() => CancelEditUser(u))" />
        </div>
       </EditTemplate>
      </RadzenDataGridColumn>
     </Columns>
    </RadzenDataGrid>
   </div>

   @* ─────────── STAMMDATEN ─────────── *@
   <div class="card">
    <div class="actions" style="margin-bottom:10px">
     <div style="min-width:180px">
      <label class="fieldLabel">Stammdaten-Typ</label>
      <RadzenDropDown TValue="string" Data="MasterTypeOptions"
                      @bind-Value="SelectedMasterType" Change="OnMasterTypeChanged" Style="width:100%" />
     </div>
     <div style="min-width:200px">
      <label class="fieldLabel">Suche</label>
      <RadzenTextBox Style="width:100%" Placeholder="Suchen…" @bind-Value="MasterSearch"
       @oninput="@(e => { MasterSearch = e.Value?.ToString() ?? ""; ApplyMasterFilter(); })" />
     </div>
     <RadzenButton Text="Neuer Eintrag" Icon="add_circle" ButtonStyle="ButtonStyle.Success" Click="AddMasterRow" />
     <RadzenButton Text="→ CSV"         Icon="download"   ButtonStyle="ButtonStyle.Light"   Click="DownloadMasterCsv" />
    </div>

    @if (SelectedMasterType == "Ort")
    {
     <RadzenDataGrid @ref="_masterGrid" TItem="MasterRow" Data="FilteredMasterRows"
                     AllowPaging="true" PageSize="8" AllowSorting="true"
                     EditMode="DataGridEditMode.Single"
                     RowUpdate="OnMasterUpdate" RowCreate="OnMasterCreate">
      <Columns>
       <RadzenDataGridColumn TItem="MasterRow" Property="RegalNr"      Title="Regal Nr">
        <EditTemplate Context="m"><RadzenNumeric TValue="int" Style="width:100%" @bind-Value="m.RegalNr" /></EditTemplate>
       </RadzenDataGridColumn>
       <RadzenDataGridColumn TItem="MasterRow" Property="Beschreibung" Title="Regal Ort">
        <EditTemplate Context="m"><RadzenTextBox Style="width:100%" @bind-Value="m.Beschreibung" /></EditTemplate>
       </RadzenDataGridColumn>
       <RadzenDataGridColumn TItem="MasterRow" Title="Aktionen" Width="200px">
        <Template Context="m"><div class="rowActions"><RadzenButton Size="ButtonSize.Small" Text="Bearb." Icon="edit" ButtonStyle="ButtonStyle.Light" Click="@(() => _masterGrid!.EditRow(m))" /><RadzenButton Size="ButtonSize.Small" Icon="delete" ButtonStyle="ButtonStyle.Danger" Click="@(() => DeleteMaster(m))" /></div></Template>
        <EditTemplate Context="m"><div class="rowActions"><RadzenButton Size="ButtonSize.Small" Text="Speichern" Icon="save" ButtonStyle="ButtonStyle.Success" Click="@(() => SaveMaster(m))" /><RadzenButton Size="ButtonSize.Small" Text="Abbruch" Icon="cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => CancelEditMaster(m))" /></div></EditTemplate>
       </RadzenDataGridColumn>
      </Columns>
     </RadzenDataGrid>
    }
    else
    {
     <RadzenDataGrid @ref="_masterGrid" TItem="MasterRow" Data="FilteredMasterRows"
                     AllowPaging="true" PageSize="8" AllowSorting="true"
                     EditMode="DataGridEditMode.Single"
                     RowUpdate="OnMasterUpdate" RowCreate="OnMasterCreate">
      <Columns>
       <RadzenDataGridColumn TItem="MasterRow" Property="Beschreibung" Title="Beschreibung">
        <EditTemplate Context="m"><RadzenTextBox Style="width:100%" @bind-Value="m.Beschreibung" /></EditTemplate>
       </RadzenDataGridColumn>
       <RadzenDataGridColumn TItem="MasterRow" Title="Aktionen" Width="200px">
        <Template Context="m"><div class="rowActions"><RadzenButton Size="ButtonSize.Small" Text="Bearb." Icon="edit" ButtonStyle="ButtonStyle.Light" Click="@(() => _masterGrid!.EditRow(m))" /><RadzenButton Size="ButtonSize.Small" Icon="delete" ButtonStyle="ButtonStyle.Danger" Click="@(() => DeleteMaster(m))" /></div></Template>
        <EditTemplate Context="m"><div class="rowActions"><RadzenButton Size="ButtonSize.Small" Text="Speichern" Icon="save" ButtonStyle="ButtonStyle.Success" Click="@(() => SaveMaster(m))" /><RadzenButton Size="ButtonSize.Small" Text="Abbruch" Icon="cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => CancelEditMaster(m))" /></div></EditTemplate>
       </RadzenDataGridColumn>
      </Columns>
     </RadzenDataGrid>
    }
   </div>

  </div>
 </div>
</div>

@* ── PASSWORT-MODAL (erscheint über dem Rest der Seite) ── *@
@if (_pwModalOpen)
{
 <div class="pw-overlay" @onclick="ClosePasswordModal">
  <div class="pw-modal" @onclick:stopPropagation>

   <div class="pw-modal-title">🔑 Passwort ändern</div>
   <div class="pw-modal-sub">@_pwModalUserName</div>

   <div class="pw-field">
    <label>Neues Passwort</label>
    <input type="password" @bind="_pwNew" @bind:event="oninput" placeholder="mind. 6 Zeichen" />
   </div>
   <div class="pw-field">
    <label>Passwort bestätigen</label>
    <input type="password" @bind="_pwConfirm" @bind:event="oninput" placeholder="wiederholen" />
   </div>

   @if (!string.IsNullOrEmpty(_pwError))
   {
    <div class="pw-error">⚠ @_pwError</div>
   }

   <div class="pw-actions">
    <button class="pw-btn-save" @onclick="SavePassword">Speichern</button>
    <button class="pw-btn-cancel" @onclick="ClosePasswordModal">Abbrechen</button>
   </div>

  </div>
 </div>
}

@code {

    // ── JS-Download-Funktion einmalig registrieren ──
    private bool _jsReady;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await JS.InvokeVoidAsync("eval", @"
(function(){
  window.invAdmin = window.invAdmin || {};
  window.invAdmin.downloadTextFile = function(name,mime,text){
    var b=new Blob([text],{type:mime}),a=document.createElement('a');
    a.href=URL.createObjectURL(b); a.download=name;
    document.body.appendChild(a); a.click(); a.remove();
  };
})();");
        _jsReady = true;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersFromDb();
        await LoadMasterFromDb();
    }


    // ════════════════════════════════════════════
    // HEADER
    // ════════════════════════════════════════════

    private bool   ShowMenu       = false;
    private string CurrentUserName = "Administrator";

    private void ToggleMenu() => ShowMenu = !ShowMenu;
    private void Logout() { ShowMenu = false; Nav.NavigateTo("/", forceLoad: true); }

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "??";
        if (parts.Length == 1) return new string(parts[0].Take(2).ToArray()).ToUpperInvariant();
        return $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}";
    }


    // ════════════════════════════════════════════
    // BENUTZERVERWALTUNG
    // ════════════════════════════════════════════

    private RadzenDataGrid<UserRow>? _usersGrid;
    private List<UserRow> Users         = new();
    private List<UserRow> FilteredUsers = new();
    private string        UserSearch    = "";

    private async Task LoadUsersFromDb()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        Users = (await db.Benutzer.ToListAsync())
            .Select(b => new UserRow { Id = b.Id, Vorname = b.Vorname ?? "", Nachname = b.Nachname ?? "", Mail = b.Mail ?? "" })
            .ToList();
        ApplyUserFilter();
    }

    private void ApplyUserFilter()
    {
        var q = UserSearch.Trim().ToLowerInvariant();
        FilteredUsers = string.IsNullOrEmpty(q)
            ? Users.ToList()
            : Users.Where(u => u.Vorname.ToLowerInvariant().Contains(q)
                            || u.Nachname.ToLowerInvariant().Contains(q)
                            || u.Mail.ToLowerInvariant().Contains(q)).ToList();
    }

    private async Task AddUserRow() { ClosePasswordModal(); await _usersGrid!.InsertRow(new UserRow()); }
    private async Task StartEditUser(UserRow u) { ClosePasswordModal(); await _usersGrid!.EditRow(u); }
    private void CancelEditUser(UserRow u) => _usersGrid?.CancelEditRow(u);

    private async Task SaveUser(UserRow u)
    {
        if (string.IsNullOrWhiteSpace(u.Vorname) || string.IsNullOrWhiteSpace(u.Nachname))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Validierung", "Vor- und Nachname dürfen nicht leer sein.");
            return;
        }
        await _usersGrid!.UpdateRow(u);
    }

    private async Task DeleteUser(UserRow u)
    {
        ClosePasswordModal();
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var b = await db.Benutzer.FindAsync(u.Id);
            if (b != null) { db.Benutzer.Remove(b); await db.SaveChangesAsync(); }
            Users.Remove(u); ApplyUserFilter();
            await _usersGrid!.Reload();
            NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Gelöscht.");
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Fehler", ex.Message); }
    }

    // Bestehenden Benutzer speichern – Passwort wird hier NICHT angefasst
    private async Task OnUserUpdate(UserRow u)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var b = await db.Benutzer.FindAsync(u.Id);
            if (b != null)
            {
                b.Vorname  = u.Vorname;
                b.Nachname = u.Nachname;
                b.Mail     = u.Mail;
                await db.SaveChangesAsync();
            }
            ApplyUserFilter();
            await _usersGrid!.Reload();
            NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Gespeichert.");
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Fehler", ex.Message); }
    }

    // Neuen Benutzer anlegen – Passwort sofort als BCrypt-Hash in DB schreiben
    private async Task OnUserCreate(UserRow u)
    {
        if (string.IsNullOrWhiteSpace(u.NeuesPasswort) || u.NeuesPasswort.Length < 6)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Validierung", "Passwort muss mindestens 6 Zeichen haben.");
            return;
        }
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var b = new Benutzer
            {
                Id       = Guid.NewGuid(),
                Vorname  = u.Vorname,
                Nachname = u.Nachname,
                Mail     = u.Mail,
                // BCryptNet ist der @using-Alias für global::BCrypt.Net.BCrypt
                Passwort = BCryptNet.HashPassword(u.NeuesPasswort)
            };
            db.Benutzer.Add(b);
            await db.SaveChangesAsync();
            u.Id = b.Id;
            Users.Insert(0, u); ApplyUserFilter();
            await _usersGrid!.Reload();
            NotificationService.Notify(NotificationSeverity.Success, "Nutzer", "Erstellt.");
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Fehler", ex.Message); }
    }


    // ════════════════════════════════════════════
    // PASSWORT-MODAL
    // ════════════════════════════════════════════

    private bool   _pwModalOpen    = false;
    private Guid   _pwModalUserId  = Guid.Empty;
    private string _pwModalUserName = "";
    private string _pwNew          = "";
    private string _pwConfirm      = "";
    private string _pwError        = "";

    private void OpenPasswordModal(UserRow u)
    {
        _pwModalUserId  = u.Id;
        _pwModalUserName = $"{u.Vorname} {u.Nachname}";
        _pwNew = _pwConfirm = _pwError = "";
        _pwModalOpen = true;
    }

    private void ClosePasswordModal()
    {
        _pwModalOpen   = false;
        _pwModalUserId = Guid.Empty;
        _pwNew = _pwConfirm = _pwError = "";
    }

    private async Task SavePassword()
    {
        _pwError = "";

        if (string.IsNullOrWhiteSpace(_pwNew) || _pwNew.Length < 6)
        {
            _pwError = "Passwort muss mindestens 6 Zeichen haben.";
            return;
        }
        if (_pwNew != _pwConfirm)
        {
            _pwError = "Passwörter stimmen nicht überein.";
            return;
        }

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var b = await db.Benutzer.FindAsync(_pwModalUserId);
            if (b != null)
            {
                // BCryptNet = Alias für global::BCrypt.Net.BCrypt → kein Namespace-Konflikt
                b.Passwort = BCryptNet.HashPassword(_pwNew);
                await db.SaveChangesAsync();
            }
            var name = _pwModalUserName;
            ClosePasswordModal();
            NotificationService.Notify(NotificationSeverity.Success, "Passwort", $"Passwort für {name} geändert.");
        }
        catch (Exception ex)
        {
            _pwError = ex.Message;
        }
    }


    // ════════════════════════════════════════════
    // STAMMDATEN
    // ════════════════════════════════════════════

    private RadzenDataGrid<MasterRow>? _masterGrid;
    private readonly List<string> MasterTypeOptions = new() { "Fach", "Abteilung", "Gruppe", "Ort" };
    private string          SelectedMasterType  = "Fach";
    private List<MasterRow> MasterRows          = new();
    private List<MasterRow> FilteredMasterRows  = new();
    private string          MasterSearch        = "";

    private async Task LoadMasterFromDb()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        MasterRows = SelectedMasterType switch
        {
            "Fach"      => (await db.Fach.ToListAsync())      .Select(x => new MasterRow { Id = x.Id, Beschreibung = x.Beschreibung ?? "" }).ToList(),
            "Abteilung" => (await db.Abteilung.ToListAsync()) .Select(x => new MasterRow { Id = x.Id, Beschreibung = x.Name ?? "" }).ToList(),
            "Gruppe"    => (await db.Gruppe.ToListAsync())     .Select(x => new MasterRow { Id = x.Id, Beschreibung = x.Name ?? "" }).ToList(),
            "Ort"       => (await db.Ort.ToListAsync())        .Select(x => new MasterRow { Id = x.Id, Beschreibung = x.RegalOrt ?? "", RegalNr = x.RegalNr }).ToList(),
            _           => new()
        };
        ApplyMasterFilter();
    }

    private void ApplyMasterFilter()
    {
        var q = MasterSearch.Trim().ToLowerInvariant();
        FilteredMasterRows = string.IsNullOrEmpty(q)
            ? MasterRows.ToList()
            : MasterRows.Where(m => m.Beschreibung.ToLowerInvariant().Contains(q)).ToList();
    }

    private async void OnMasterTypeChanged(object? _)
    {
        MasterSearch = "";
        await LoadMasterFromDb();
        if (_masterGrid != null) await _masterGrid.Reload();
        StateHasChanged();
    }

    private async Task AddMasterRow()              => await _masterGrid!.InsertRow(new MasterRow());
    private void      CancelEditMaster(MasterRow m) => _masterGrid?.CancelEditRow(m);

    private async Task SaveMaster(MasterRow m)
    {
        if (string.IsNullOrWhiteSpace(m.Beschreibung))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Validierung", "Beschreibung darf nicht leer sein.");
            return;
        }
        await _masterGrid!.UpdateRow(m);
    }

    private async Task DeleteMaster(MasterRow m)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            switch (SelectedMasterType)
            {
                case "Fach":      var f = await db.Fach.FindAsync(m.Id);      if (f != null) { db.Fach.Remove(f);      await db.SaveChangesAsync(); } break;
                case "Abteilung": var a = await db.Abteilung.FindAsync(m.Id); if (a != null) { db.Abteilung.Remove(a); await db.SaveChangesAsync(); } break;
                case "Gruppe":    var g = await db.Gruppe.FindAsync(m.Id);    if (g != null) { db.Gruppe.Remove(g);    await db.SaveChangesAsync(); } break;
                case "Ort":       var o = await db.Ort.FindAsync(m.Id);       if (o != null) { db.Ort.Remove(o);       await db.SaveChangesAsync(); } break;
            }
            MasterRows.Remove(m); ApplyMasterFilter();
            await _masterGrid!.Reload();
            NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Gelöscht.");
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Fehler", ex.Message); }
    }

    private async Task OnMasterUpdate(MasterRow m)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            switch (SelectedMasterType)
            {
                case "Fach":      var f = await db.Fach.FindAsync(m.Id);      if (f != null) { f.Beschreibung = m.Beschreibung;                        await db.SaveChangesAsync(); } break;
                case "Abteilung": var a = await db.Abteilung.FindAsync(m.Id); if (a != null) { a.Name         = m.Beschreibung;                        await db.SaveChangesAsync(); } break;
                case "Gruppe":    var g = await db.Gruppe.FindAsync(m.Id);    if (g != null) { g.Name         = m.Beschreibung;                        await db.SaveChangesAsync(); } break;
                case "Ort":       var o = await db.Ort.FindAsync(m.Id);       if (o != null) { o.RegalOrt     = m.Beschreibung; o.RegalNr = m.RegalNr; await db.SaveChangesAsync(); } break;
            }
            ApplyMasterFilter();
            await _masterGrid!.Reload();
            NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Gespeichert.");
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Fehler", ex.Message); }
    }

    private async Task OnMasterCreate(MasterRow m)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            switch (SelectedMasterType)
            {
                case "Fach":      var f = new Fach      { Id = Guid.NewGuid(), Beschreibung = m.Beschreibung };                      db.Fach.Add(f);      await db.SaveChangesAsync(); m.Id = f.Id; break;
                case "Abteilung": var a = new Abteilung { Id = Guid.NewGuid(), Name         = m.Beschreibung };                      db.Abteilung.Add(a); await db.SaveChangesAsync(); m.Id = a.Id; break;
                case "Gruppe":    var g = new Gruppe    { Id = Guid.NewGuid(), Name         = m.Beschreibung };                      db.Gruppe.Add(g);    await db.SaveChangesAsync(); m.Id = g.Id; break;
                case "Ort":       var o = new Ort       { Id = Guid.NewGuid(), RegalOrt = m.Beschreibung, RegalNr = m.RegalNr };     db.Ort.Add(o);       await db.SaveChangesAsync(); m.Id = o.Id; break;
            }
            MasterRows.Insert(0, m); ApplyMasterFilter();
            await _masterGrid!.Reload();
            NotificationService.Notify(NotificationSeverity.Success, "Stammdaten", "Erstellt.");
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Fehler", ex.Message); }
    }


    // ════════════════════════════════════════════
    // CSV-EXPORT
    // ════════════════════════════════════════════

    private string UsersToCsv()
    {
        var sb = new StringBuilder("Vorname;Nachname;Mail\n");
        foreach (var u in FilteredUsers) sb.AppendLine($"{Clean(u.Vorname)};{Clean(u.Nachname)};{Clean(u.Mail)}");
        return sb.ToString();
    }

    private string MasterToCsv()
    {
        var sb = new StringBuilder();
        if (SelectedMasterType == "Ort") { sb.AppendLine("RegalNr;RegalOrt"); foreach (var m in FilteredMasterRows) sb.AppendLine($"{m.RegalNr};{Clean(m.Beschreibung)}"); }
        else { sb.AppendLine("Typ;Beschreibung"); foreach (var m in FilteredMasterRows) sb.AppendLine($"{Clean(SelectedMasterType)};{Clean(m.Beschreibung)}"); }
        return sb.ToString();
    }

    private static string Clean(string s) => (s ?? "").Replace(";", ",").Replace("\n", " ").Replace("\r", " ").Trim();

    private async Task DownloadUsersCsv()  { if (_jsReady) await JS.InvokeVoidAsync("invAdmin.downloadTextFile", "benutzer.csv", "text/csv;charset=utf-8", UsersToCsv()); }
    private async Task DownloadMasterCsv() { if (_jsReady) await JS.InvokeVoidAsync("invAdmin.downloadTextFile", $"stammdaten_{SelectedMasterType}.csv", "text/csv;charset=utf-8", MasterToCsv()); }


