@page "/login"
@inject NavigationManager Nav

<style>
    /*Seite*/
    .iv-page {
        min-height: 100vh;
        background: #f3f5f9;
        padding: 24px 16px;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;
        color: #111827;
    }

    /*Header*/
    .iv-header {
        max-width: 900px;
        margin: 0 auto 22px;
        border-radius: 14px;
        background: linear-gradient(90deg, #1f4ea8, #2a64d6);
        box-shadow: 0 8px 18px rgba(0,0,0,.12);
        padding: 14px 18px;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 14px;
    }

    .iv-logo {
        height: 44px;
        width: auto;
        object-fit: contain;
        filter: drop-shadow(0 2px 2px rgba(0,0,0,.18));
    }

    /*LoginBox*/
    .iv-main {
        max-width: 900px;
        margin: 0 auto;
    }

    .iv-card {
        max-width: 420px;
        margin: 0 auto;
        background: white;
        border-radius: 16px;
        padding: 26px;
        box-shadow: 0 10px 24px rgba(0,0,0,.10);
        border: 1px solid rgba(0,0,0,.06);
    }

        .iv-card h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 900;
            letter-spacing: .2px;
        }

    .iv-sub {
        margin: 8px 0 18px;
        color: #6b7280;
        font-size: 14px;
    }

    /*Input*/
    .iv-field {
        margin-bottom: 14px;
    }

        .iv-field label {
            display: block;
            font-weight: 700;
            margin-bottom: 6px;
            font-size: 13px;
            /*color: #374151;*/
        }

    .iv-input {
        width: 100%;
        padding: 10px 12px;
        border-radius: 12px;
        border: 1px solid rgba(0,0,0,.18);
        background: #fbfcfe;
        outline: none;
        font-size: 14px;
    }

    /*Button*/
    .iv-btn {
        width: 100%;
        padding: 11px 12px;
        border: none;
        border-radius: 12px;
        background: #2a64d6;
        color: white;
        font-size: 15px;
        font-weight: 800;
        cursor: pointer;
        box-shadow: 0 10px 18px rgba(42,100,214,.18);
    }

    /*Errormeldung*/
    .iv-error {
        background: rgba(220, 38, 38, .08);
        border: 1px solid rgba(220, 38, 38, .20);
        padding: 10px 12px;
        border-radius: 12px;
        color: #b42318;
        margin-bottom: 12px;
        font-weight: 700;
        font-size: 13px;
    }

</style>

<div class="iv-page">

    <div class="iv-header">
        <img class="iv-logo" src="logo_header.jpg" alt="Logo" />
    </div>

    <div class="iv-main">
        <div class="iv-card">

            <h1>Anmelden</h1>
            <p class="iv-sub">Bitte melde dich an, um fortzufahren.</p>

            <div class="iv-field">
                <label>Benutzername</label>
                <input class="iv-input" @bind="_username" placeholder="z.B. user" />
            </div>

            <div class="iv-field">
                <label>Passwort</label>
                <input class="iv-input" type="password" @bind="_password" placeholder="••••••••" />
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="iv-error">@_error</div>
            }

            <button class="iv-btn" type="button" @onclick="DoLogin">
                Login
            </button>

        </div>
    </div>

</div>

    @code {
    string _username = "";
    string _password = "";
    string? _error;

    void DoLogin()
    {
        _error = null;

        if (_username == "admin" && _password == "admin")
        {
            Nav.NavigateTo("/admin", true);
            return;
        }

        if (_username == "user" && _password == "user")
        {
            Nav.NavigateTo("/hauptmenu", true);
            return;
        }

        _error = "Benutzername oder Passwort falsch!";
    }
}